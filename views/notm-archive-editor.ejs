<%- include('partials/admin-header', { title: 'Hall of Fame', active: 'dashboard' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">NOTM Archive</h2>
    <p class="text-muted mb-0">Historical records of Ninjas and Senseis of the Month.</p>
  </div>
  <button class="btn btn-outline-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#archiveModal">
    <i class="bi bi-archive-fill me-2"></i> Archive Current Month
  </button>
</div>

<div class="admin-card overflow-hidden shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-4 py-3">Month / Year</th>
          <th class="py-3">Ninja(s) of the Month</th>
          <th class="py-3">Sensei of the Month</th>
          <th class="text-end pe-4 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (archive && archive.length > 0) { %>
          <% archive.forEach(entry => { %>
            <tr>
              <td class="ps-4 fw-bold text-dark"><%= entry.month %> <%= entry.year %></td>
              <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3"><%= entry.ninjaOfTheMonth %></span></td>
              <td class="text-muted"><%= entry.senseiOfTheMonth %></td>
              <td class="text-end pe-4">
                <button class="btn btn-sm btn-outline-danger" onclick="deleteEntry('<%= entry._id %>')"><i class="bi bi-trash"></i></button>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="4" class="text-center py-5 text-muted">No archive records found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Archive Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold">Archive Month</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <p class="text-muted small mb-4">This will save the current Ninja of the Month settings into the permanent archive.</p>
        <button class="btn btn-primary w-100 rounded-pill py-3 fw-bold" onclick="archiveCurrent()">
          <i class="bi bi-check2-circle me-2"></i> Confirm and Save
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  async function archiveCurrent() {
    try {
      const res = await fetch('/admin/archive-month', { method: 'POST' });
      if(res.ok) location.reload();
    } catch (e) { alert('Network error.'); }
  }

  async function deleteEntry(id) {
    if(!confirm('Permanently delete this archive record?')) return;
    try {
      const res = await fetch(`/admin/hall-of-fame/delete/${id}`, { method: 'POST' });
      if(res.ok) location.reload();
      else alert('Failed to delete record.');
    } catch(e) { alert('Network error.'); }
  }
</script>

<%- include('partials/admin-footer') %>
