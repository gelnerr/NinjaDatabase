<%- include('partials/admin-header', { title: 'Advancement History', active: 'logs' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">Belt Advancement History</h2>
    <p class="text-muted mb-0">Chronological history of ninja rank updates.</p>
  </div>
  <button class="btn btn-primary rounded-pill px-4" onclick="postToDiscord()">
    <i class="bi bi-discord me-2"></i> Post Pending to Discord
  </button>
</div>

<div class="admin-card overflow-hidden shadow-sm">
  <div class="p-4 border-bottom bg-light">
     <div class="fw-bold text-dark">
       <i class="bi bi-journal-check me-2"></i> Recent Advancements
     </div>
  </div>
  
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-4">Date</th>
          <th>Ninja Name</th>
          <th>Rank Advancement</th>
          <th>Discord Status</th>
          <th class="text-end pe-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length > 0) { %>
          <% logs.forEach(log => { %>
            <tr>
              <td class="ps-4 text-muted small">
                <%= new Date(log.date).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </td>
              <td class="fw-bold text-dark"><%= log.ninjaName %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <span class="badge belt-badge belt-<%= (log.oldBelt || 'white').toLowerCase().replace(' ', '-') %>"><%= log.oldBelt || 'White' %></span>
                  <i class="bi bi-arrow-right text-muted"></i>
                  <span class="badge belt-badge belt-<%= (log.newBelt || 'white').toLowerCase().replace(' ', '-') %>"><%= log.newBelt %></span>
                </div>
                <% if(log.notes) { %>
                  <div class="small text-muted mt-1 italic"><i class="bi bi-info-circle me-1"></i><%= log.notes %></div>
                <% } %>
              </td>
              <td>
                <% if (log.discordPosted) { %>
                  <span class="badge bg-success-subtle text-success border border-success border-opacity-25"><i class="bi bi-check-circle-fill me-1"></i> Posted</span>
                <% } else { %>
                  <span class="badge bg-warning-subtle text-warning border border-warning border-opacity-25 text-dark"><i class="bi bi-hourglass-split me-1"></i> Pending</span>
                <% } %>
              </td>
              <td class="text-end pe-4">
                <button class="btn btn-sm btn-outline-danger" onclick="deleteLog('<%= log._id %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center py-5 text-muted">
              <i class="bi bi-clipboard-x fs-2 d-block mb-2"></i> No advancement records found.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<style>
  .belt-badge { min-width: 90px; border: 1px solid rgba(0,0,0,0.1); font-weight: 700; text-transform: uppercase; font-size: 0.65rem; }
</style>

<script>
  async function postToDiscord() {
    if(!confirm('Post all pending belt updates to Discord?')) return;
    try {
      const res = await fetch('/admin/progress-log/post-discord', { method: 'POST' });
      const result = await res.json();
      if(result.success) {
        alert(`Success! Posted ${result.count} updates.`);
        location.reload();
      }
    } catch (e) { alert('Network error.'); }
  }

  async function deleteLog(id) {
    if(!confirm('Delete this history record?')) return;
    try {
      const res = await fetch(`/admin/progress-log/delete/${id}`, { method: 'POST' });
      if(res.ok) location.reload();
    } catch (e) { alert('Network error.'); }
  }
</script>

<%- include('partials/admin-footer') %>
