<%- include('partials/admin-header', { title: 'Advancement History', active: 'logs' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">Belt Advancement History</h2>
    <p class="text-muted mb-0">Chronological history of ninja rank updates.</p>
  </div>
  <div class="d-flex gap-2">
    <button class="btn btn-outline-secondary rounded-pill px-4" onclick="testDiscordWebhook()" id="discordTestBtn">
      <i class="bi bi-broadcast me-2"></i> Test Discord Webhook
    </button>
    <button class="btn btn-primary rounded-pill px-4" onclick="postToDiscord()">
      <i class="bi bi-discord me-2"></i> Post Pending to Discord
    </button>
  </div>
</div>

<div id="discordTestResults" class="admin-card p-4 shadow-sm mb-4" style="display:none;">
  <div id="discordTestList" class="mb-2"></div>
  <div id="discordTestSummary" class="small fw-bold mt-2 p-3 rounded-3"></div>
</div>

<div class="admin-card overflow-hidden shadow-sm">
  <div class="p-4 border-bottom bg-light">
     <div class="fw-bold text-dark">
       <i class="bi bi-journal-check me-2"></i> Recent Advancements
     </div>
  </div>
  
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-4">Date</th>
          <th>Ninja Name</th>
          <th>Rank Advancement</th>
          <th>Discord Status</th>
          <th class="text-end pe-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length > 0) { %>
          <% logs.forEach(log => { %>
            <tr>
              <td class="ps-4 text-muted small">
                <%= new Date(log.date).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </td>
              <td class="fw-bold text-dark"><%= log.ninjaName %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <span class="badge belt-badge belt-<%= (log.oldBelt || 'white').toLowerCase().replace(' ', '-') %>"><%= log.oldBelt || 'White' %></span>
                  <i class="bi bi-arrow-right text-muted"></i>
                  <span class="badge belt-badge belt-<%= (log.newBelt || 'white').toLowerCase().replace(' ', '-') %>"><%= log.newBelt %></span>
                </div>
                <% if(log.notes) { %>
                  <div class="small text-muted mt-1 italic"><i class="bi bi-info-circle me-1"></i><%= log.notes %></div>
                <% } %>
              </td>
              <td>
                <% if (log.discordPosted) { %>
                  <span class="badge bg-success-subtle text-success border border-success border-opacity-25"><i class="bi bi-check-circle-fill me-1"></i> Posted</span>
                <% } else { %>
                  <span class="badge bg-warning-subtle text-warning border border-warning border-opacity-25 text-dark"><i class="bi bi-hourglass-split me-1"></i> Pending</span>
                <% } %>
              </td>
              <td class="text-end pe-4">
                <button class="btn btn-sm btn-outline-danger" onclick="deleteLog('<%= log._id %>')">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center py-5 text-muted">
              <i class="bi bi-clipboard-x fs-2 d-block mb-2"></i> No advancement records found.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<style>
  .belt-badge { min-width: 90px; border: 1px solid rgba(0,0,0,0.1); font-weight: 700; text-transform: uppercase; font-size: 0.65rem; }
</style>

<script>
  async function testDiscordWebhook() {
    const btn = document.getElementById('discordTestBtn');
    const results = document.getElementById('discordTestResults');
    const list = document.getElementById('discordTestList');
    const summary = document.getElementById('discordTestSummary');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Testing...';
    results.style.display = 'none';

    try {
      const res = await fetch('/admin/test-discord', { method: 'POST' });
      const data = await res.json();

      list.innerHTML = data.steps.map(s => `
        <div class="d-flex align-items-start gap-2 mb-2">
          <span class="mt-1">${s.ok ? '✅' : '❌'}</span>
          <div>
            <div class="small fw-bold ${s.ok ? 'text-dark' : 'text-danger'}">${s.label}</div>
            ${s.detail ? `<div class="small text-muted" style="word-break:break-all;">${s.detail}</div>` : ''}
          </div>
        </div>
      `).join('');

      if (data.success) {
        summary.className = 'small fw-bold mt-2 p-3 rounded-3 bg-success bg-opacity-10 text-success border border-success border-opacity-25';
        summary.textContent = '✅ Test message sent — check your Discord channel to confirm it landed in the right place.';
      } else {
        const failed = data.steps.find(s => !s.ok);
        summary.className = 'small fw-bold mt-2 p-3 rounded-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25';
        summary.textContent = `❌ Failed at: "${failed?.label}". See detail above.`;
      }
      results.style.display = 'block';
    } catch(e) {
      list.innerHTML = `<div class="text-danger small">Network error: ${e.message}</div>`;
      results.style.display = 'block';
    }

    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-broadcast me-2"></i> Test Discord Webhook';
  }

  async function postToDiscord() {
    if(!confirm('Post all pending belt updates to Discord?')) return;
    try {
      const res = await fetch('/admin/progress-log/post-discord', { method: 'POST' });
      const result = await res.json();
      if(result.success) {
        alert(`Success! Posted ${result.count} updates.`);
        location.reload();
      }
    } catch (e) { alert('Network error.'); }
  }

  async function deleteLog(id) {
    if(!confirm('Delete this history record?')) return;
    try {
      const res = await fetch(`/admin/progress-log/delete/${id}`, { method: 'POST' });
      if(res.ok) location.reload();
    } catch (e) { alert('Network error.'); }
  }
</script>

<%- include('partials/admin-footer') %>
