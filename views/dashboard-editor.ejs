<%- include('partials/admin-header', { title: 'Dashboard Settings', active: 'editor' }) %>

<div class="page-header d-flex justify-content-between align-items-center">
  <div>
    <h2 class="page-title">Lobby Dashboard Settings</h2>
    <p class="text-muted mb-0">Configure what ninjas see on the large display in the lobby.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/notm-archive-editor" class="btn btn-outline-primary rounded-pill px-4">
      <i class="bi bi-archive me-2"></i> Archive NOTM
    </a>
    <button type="submit" form="dashboardForm" class="btn btn-primary rounded-pill px-4 shadow-sm">
      <i class="bi bi-cloud-upload-fill me-2"></i> Save All Changes
    </button>
  </div>
</div>

<form id="dashboardForm" action="/admin/update-dashboard" method="POST">
  <div class="row">
    <!-- Left Column: Core Display Settings -->
    <div class="col-lg-4">
      <div class="admin-card p-4 shadow-sm mb-4">
        <h5 class="fw-bold mb-4"><i class="bi bi-display text-primary me-2"></i> Display Config</h5>
        
        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase text-muted">Award Month</label>
          <input type="text" name="notmMonth" class="form-control" value="<%= data.notmMonth %>" placeholder="e.g. October 2025">
        </div>
        
        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase text-muted">Branding Color</label>
          <input type="color" name="notmColor" class="form-control form-control-color w-100" value="<%= data.notmColor || '#358ebc' %>">
        </div>

        <div class="mb-3">
          <label class="form-label small fw-bold text-uppercase text-muted">Lobby Display Theme</label>
          <select name="theme" class="form-select">
            <option value="classic"   <%= data.theme === 'classic'   ? 'selected' : '' %>>Classic Dojo (Default)</option>
            <option value="space"     <%= data.theme === 'space'     ? 'selected' : '' %>>Outer Space</option>
            <option value="cyber"     <%= data.theme === 'cyber'     ? 'selected' : '' %>>Cyber / Tech</option>
            <option value="deepsea"   <%= data.theme === 'deepsea'   ? 'selected' : '' %>>Deep Sea</option>
            <option value="undertale" <%= data.theme === 'undertale' ? 'selected' : '' %>>Undertale</option>
          </select>
          <div class="form-text mt-1 small">Controls the theme on the main lobby screen at <code>/</code></div>
        </div>

        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">Background Image URL</label>
          <input type="text" name="backgroundImage" class="form-control" value="<%= data.backgroundImage %>" placeholder="https://...">
          <div class="form-text mt-1 small">Leave blank for theme default. Supports high-res images.</div>
        </div>

        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">Daily Activity Start <span class="text-muted fw-normal">(minute of each hour)</span></label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-alarm-fill"></i></span>
            <input type="number" name="activityStartMinute" class="form-control border-start-0" min="0" max="59" value="<%= data.activityStartMinute ?? 45 %>" style="max-width: 100px;">
            <span class="input-group-text bg-light border-start-0 text-muted">/ 59</span>
          </div>
          <div class="form-text mt-1 small">Timer switches to "Daily Activity!" at this minute each hour. Default: 45 (i.e. xx:45).</div>
        </div>

        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">Sensei Voting Link</label>
          <input type="url" name="senseiVotingLink" class="form-control" value="<%= data.senseiVotingLink %>" placeholder="https://forms.gle/...">
        </div>
        
        <div class="mb-0">
          <label class="form-label small fw-bold text-uppercase text-muted">Sensei of the Month</label>
          <input type="text" name="senseiOfMonth" class="form-control" value="<%= data.senseiOfMonth %>">
        </div>
      </div>

      <div class="admin-card p-4 shadow-sm mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-lightbulb-fill text-info me-2"></i> Fun Fact</h5>
        <textarea name="funFact" class="form-control" rows="4" placeholder="Enter an interesting fact for the ninjas..."><%= data.funFact %></textarea>
      </div>
    </div>

    <!-- Right Column: Interactive Content -->
    <div class="col-lg-8">
      <!-- Ninjas of the Month Section -->
      <div class="admin-card p-4 shadow-sm mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="fw-bold mb-0"><i class="bi bi-people-fill text-warning me-2"></i> Ninjas of the Month</h5>
          <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3" onclick="addNOTM()">
            <i class="bi bi-plus-lg me-1"></i> Add NOTM
          </button>
        </div>
        
        <div id="notmList" class="row g-3">
          <% (data.ninjasOfTheMonth || []).forEach((n, i) => { %>
            <div class="col-md-6 notm-item">
              <div class="border rounded-4 p-3 bg-light position-relative">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" onclick="this.closest('.notm-item').remove()"></button>
                <div class="mb-2">
                  <label class="small text-muted fw-bold">Ninja Name</label>
                  <input type="text" name="notm_name_<%= i %>" class="form-control form-control-sm" value="<%= n.name %>" required>
                </div>
                <div class="row g-2">
                  <div class="col-6">
                    <label class="small text-muted fw-bold">Category</label>
                    <select name="notm_type_<%= i %>" class="form-select form-select-sm">
                      <option value="Focused" <%= n.type === 'Focused' ? 'selected' : '' %>>Focused</option>
                      <option value="Friendly" <%= n.type === 'Friendly' ? 'selected' : '' %>>Friendly</option>
                      <option value="Helpful" <%= n.type === 'Helpful' ? 'selected' : '' %>>Helpful</option>
                      <option value="Creative" <%= n.type === 'Creative' ? 'selected' : '' %>>Creative</option>
                      <option value="Scholar" <%= n.type === 'Scholar' ? 'selected' : '' %>>Scholar</option>
                      <option value="Skillful" <%= n.type === 'Skillful' ? 'selected' : '' %>>Skillful</option>
                      <option value="Collector" <%= n.type === 'Collector' ? 'selected' : '' %>>Collector</option>
                      <option value="Surprise" <%= n.type === 'Surprise' ? 'selected' : '' %>>Surprise</option>
                      <option value="Challenge" <%= n.type === 'Challenge' ? 'selected' : '' %>>Challenge</option>
                    </select>
                  </div>
                  <div class="col-6">
                    <label class="small text-muted fw-bold">Image URL</label>
                    <input type="text" name="notm_image_<%= i %>" class="form-control form-control-sm" value="<%= n.image %>" placeholder="/img/notm/focused.png">
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Dojo Events Section -->
      <div class="admin-card p-4 shadow-sm mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="fw-bold mb-0"><i class="bi bi-calendar-event-fill text-danger me-2"></i> Dojo Events</h5>
          <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="addEvent()">
            <i class="bi bi-plus-lg me-1"></i> Add Event
          </button>
        </div>
        <div id="eventList">
          <% (data.specialEvents || []).forEach((ev, i) => { %>
            <div class="event-row row g-2 mb-2 align-items-center">
              <div class="col-md-3">
                <input type="text" name="events_date_<%= i %>" class="form-control form-control-sm" value="<%= ev.date %>" placeholder="e.g. Dec 20">
              </div>
              <div class="col-md-8">
                <input type="text" name="events_text_<%= i %>" class="form-control form-control-sm" value="<%= ev.text %>" placeholder="Event description">
              </div>
              <div class="col-md-1">
                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="this.closest('.event-row').remove()"><i class="bi bi-trash"></i></button>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Weekly Activities Section -->
      <div class="admin-card p-4 shadow-sm mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="fw-bold mb-0"><i class="bi bi-calendar-week text-success me-2"></i> Weekly Activities</h5>
          <span class="badge bg-light text-dark border">Auto-Rotates</span>
        </div>

        <ul class="nav nav-pills mb-4" id="activityTabs" role="tablist">
          <li class="nav-item">
            <button class="nav-link active rounded-pill px-4 me-2" data-bs-toggle="pill" data-bs-target="#this-week" type="button">This Week</button>
          </li>
          <li class="nav-item">
            <button class="nav-link rounded-pill px-4" data-bs-toggle="pill" data-bs-target="#next-week" type="button">Next Week</button>
          </li>
        </ul>

        <div class="tab-content">
          <div class="tab-pane fade show active" id="this-week">
            <div id="thisWeekList">
              <% (data.activitiesThisWeek || []).forEach((act, i) => { %>
                <div class="activity-row row g-2 mb-3 align-items-end">
                  <div class="col-md-5">
                    <label class="small text-muted mb-1">Description</label>
                    <input type="text" name="activitiesThisWeek_desc_<%= i %>" class="form-control" value="<%= act.description %>">
                  </div>
                  <div class="col-md-4">
                    <label class="small text-muted mb-1">Image URL</label>
                    <input type="text" name="activitiesThisWeek_url_<%= i %>" class="form-control" value="<%= act.image %>">
                  </div>
                  <div class="col-md-2">
                    <label class="small text-muted mb-1">Link/Slug</label>
                    <input type="text" name="activitiesThisWeek_link_<%= i %>" class="form-control" value="<%= act.link %>">
                  </div>
                  <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger w-100" onclick="this.parentElement.parentElement.remove()"><i class="bi bi-trash"></i></button>
                  </div>
                </div>
              <% }); %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addActivity('thisWeekList', 'activitiesThisWeek')">
              <i class="bi bi-plus-lg me-1"></i> Add Activity
            </button>
          </div>
          
          <div class="tab-pane fade" id="next-week">
            <div id="nextWeekList">
              <% (data.activitiesNextWeek || []).forEach((act, i) => { %>
                <div class="activity-row row g-2 mb-3 align-items-end">
                  <div class="col-md-5">
                    <label class="small text-muted mb-1">Description</label>
                    <input type="text" name="activitiesNextWeek_desc_<%= i %>" class="form-control" value="<%= act.description %>">
                  </div>
                  <div class="col-md-4">
                    <label class="small text-muted mb-1">Image URL</label>
                    <input type="text" name="activitiesNextWeek_url_<%= i %>" class="form-control" value="<%= act.image %>">
                  </div>
                  <div class="col-md-2">
                    <label class="small text-muted mb-1">Link/Slug</label>
                    <input type="text" name="activitiesNextWeek_link_<%= i %>" class="form-control" value="<%= act.link %>">
                  </div>
                  <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger w-100" onclick="this.parentElement.parentElement.remove()"><i class="bi bi-trash"></i></button>
                  </div>
                </div>
              <% }); %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addActivity('nextWeekList', 'activitiesNextWeek')">
              <i class="bi bi-plus-lg me-1"></i> Add Activity
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

<script>
  function addEvent() {
    const container = document.getElementById('eventList');
    const idx = Date.now();
    const row = document.createElement('div');
    row.className = 'event-row row g-2 mb-2 align-items-center';
    row.innerHTML = `
      <div class="col-md-3">
        <input type="text" name="events_date_${idx}" class="form-control form-control-sm" placeholder="e.g. Dec 20">
      </div>
      <div class="col-md-8">
        <input type="text" name="events_text_${idx}" class="form-control form-control-sm" placeholder="Event description">
      </div>
      <div class="col-md-1">
        <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="this.closest('.event-row').remove()"><i class="bi bi-trash"></i></button>
      </div>`;
    container.appendChild(row);
  }

  function addActivity(containerId, prefix) {
    const container = document.getElementById(containerId);
    const index = Date.now() + Math.random(); // Unique-ish index
    const div = document.createElement('div');
    div.className = 'activity-row row g-2 mb-3 align-items-end';
    div.innerHTML = `
      <div class="col-md-5">
        <input type="text" name="${prefix}_desc_${index}" class="form-control" placeholder="Activity name">
      </div>
      <div class="col-md-4">
        <input type="text" name="${prefix}_url_${index}" class="form-control" placeholder="/img/...">
      </div>
      <div class="col-md-2">
        <input type="text" name="${prefix}_link_${index}" class="form-control" placeholder="Link slug">
      </div>
      <div class="col-md-1">
        <button type="button" class="btn btn-outline-danger w-100" onclick="this.parentElement.parentElement.remove()"><i class="bi bi-trash"></i></button>
      </div>
    `;
    container.appendChild(div);
  }

  function addNOTM() {
    const container = document.getElementById('notmList');
    const index = Date.now() + Math.random();
    const div = document.createElement('div');
    div.className = 'col-md-6 notm-item';
    div.innerHTML = `
      <div class="border rounded-4 p-3 bg-light position-relative">
        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" onclick="this.closest('.notm-item').remove()"></button>
        <div class="mb-2">
          <label class="small text-muted fw-bold">Ninja Name</label>
          <input type="text" name="notm_name_${index}" class="form-control form-control-sm" required>
        </div>
        <div class="row g-2">
          <div class="col-6">
            <label class="small text-muted fw-bold">Category</label>
            <select name="notm_type_${index}" class="form-select form-select-sm">
              <option value="Focused">Focused</option>
              <option value="Friendly">Friendly</option>
              <option value="Helpful">Helpful</option>
              <option value="Creative">Creative</option>
              <option value="Scholar">Scholar</option>
              <option value="Skillful">Skillful</option>
              <option value="Collector">Collector</option>
              <option value="Surprise">Surprise</option>
              <option value="Challenge">Challenge</option>
            </select>
          </div>
          <div class="col-6">
            <label class="small text-muted fw-bold">Image URL</label>
            <input type="text" name="notm_image_${index}" class="form-control form-control-sm" placeholder="/img/notm/focused.png">
          </div>
        </div>
      </div>
    `;
    container.appendChild(div);
  }
</script>

<%- include('partials/admin-footer') %>
