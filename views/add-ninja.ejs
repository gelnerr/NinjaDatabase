<%- include('partials/admin-header', { title: 'Add Ninja', active: 'data' }) %>

<div class="page-header">
  <h2 class="page-title">Add New Ninja</h2>
  <p class="text-muted">Register a new member into the Dojo database.</p>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="admin-card p-4 p-md-5 shadow-sm">
      <form action="/admin/add-ninja" method="POST">
        <div class="mb-4">
          <label class="form-label fw-bold text-dark">Full Name</label>
          <input type="text" name="name" class="form-control form-control-lg" placeholder="e.g. John Doe" required autofocus>
        </div>

        <div class="mb-4">
          <label class="form-label fw-bold text-dark">Initial Belt Rank</label>
          <select name="currentBelt" class="form-select">
            <% ['White', 'Yellow', 'Orange', 'Green', 'Blue', 'Purple', 'Brown', 'Red', 'Black', 'Bronze', 'Silver', 'Platinum', 'Gold', 'Going Gold'].forEach(belt => { %>
              <option value="<%= belt %>"><%= belt %></option>
            <% }); %>
          </select>
        </div>

        <div class="mb-5">
          <label class="form-label fw-bold text-dark">Starting NinjaBucks</label>
          <div class="input-group">
            <span class="input-group-text bg-light"><i class="bi bi-coin"></i></span>
            <input type="number" name="totalNinjaBucks" class="form-control" value="0" min="0">
          </div>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">
            <i class="bi bi-person-plus-fill me-2"></i> Create Profile
          </button>
          <a href="/admin/master-data" class="btn btn-link text-muted mt-2">Cancel and Go Back</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
