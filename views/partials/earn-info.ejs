<div class="accordion mb-4" id="earnInfoAccordion">
  <div class="accordion-item card border-0 shadow-sm overflow-hidden">
    <h2 class="accordion-header" id="headingEarn">
      <button class="accordion-button collapsed fw-bold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEarn" aria-expanded="false" aria-controls="collapseEarn" style="background: linear-gradient(135deg, #fff 0%, #f8fbff 100%); color: var(--cn-blue);">
        <i class="bi bi-info-circle-fill me-2"></i> How to Earn Ninja Bucks
      </button>
    </h2>
    <div id="collapseEarn" class="accordion-collapse collapse" aria-labelledby="headingEarn" data-bs-parent="#earnInfoAccordion">
      <div class="accordion-body p-0">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
              <tr>
                <th class="ps-4 py-2" style="width: 80%;">Achievement</th>
                <th class="text-end pe-4 py-2">Reward</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="ps-4 py-3">
                  <ul class="mb-0 ps-3 small">
                    <li>Complete an Activity (for IMPACT, only Build, Quest, and Adventure)</li>
                    <li>Complete a Daily Activity Challenge</li>
                    <li>Be Creative with your project and show Sensei (for IMPACT, max 1 NB per Adventure project only)</li>
                    <li>Publish a Community game and show Sensei (max: 2 games per month)</li>
                  </ul>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">1 NB</td>
              </tr>
              <tr>
                <td class="ps-4 py-3">
                  <ul class="mb-0 ps-3 small">
                    <li>Level up on IMPACT</li>
                    <li>Get a Stripe</li>
                  </ul>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">2 NB</td>
              </tr>
              <tr>
                <td class="ps-4 py-3">
                  <ul class="mb-0 ps-3 small">
                    <li>Belt up</li>
                    <li>Complete a Boss Badge</li>
                    <li>It is your Birthday</li>
                    <li>Ninja of the Month</li>
                  </ul>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">5 NB</td>
              </tr>
              <tr>
                <td class="ps-4 py-3">
                  <ul class="mb-0 ps-3 small">
                    <li>Follow the Rules of the Dojo</li>
                  </ul>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">up to 5 NB</td>
              </tr>
              <tr>
                <td class="ps-4 py-3">
                  <ul class="mb-0 ps-3 small">
                    <li>Participate in a Game Jam (game building competition)</li>
                  </ul>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">10 NB</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
