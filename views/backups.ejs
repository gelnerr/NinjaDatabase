<%- include('partials/admin-header', { title: 'Backups', active: 'backups' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">Database Backups</h2>
    <p class="text-muted mb-0">System snapshots and recovery points.</p>
  </div>
</div>

<div class="row">
  <div class="col-lg-12">
    <div class="admin-card shadow-sm overflow-hidden">
      <div class="p-4 border-bottom bg-light d-flex justify-content-between align-items-center">
        <div class="fw-bold text-dark">
          <i class="bi bi-shield-check me-2 text-success"></i> Available Snapshots
        </div>
        <div class="text-muted small">
          Auto-generated before every migration
        </div>
      </div>
      
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Backup Name / ID</th>
              <th>Created Date</th>
              <th class="text-end pe-4">System Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (backups.length > 0) { %>
              <% backups.forEach(file => { %>
                <tr>
                  <td class="ps-4">
                    <div class="d-flex align-items-center">
                      <i class="bi bi-file-earmark-code fs-4 me-3 text-primary opacity-50"></i>
                      <div>
                        <span class="fw-bold text-dark"><%= file %></span>
                      </div>
                    </div>
                  </td>
                  <td class="text-muted">
                    <%= file.includes('db-backup-') ? file.replace('db-backup-', '').replace('.json', '').replace(/-/g, ':').replace('T', ' ').substring(0, 16) : 'Legacy' %>
                  </td>
                  <td class="text-end pe-4">
                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                      <button class="btn btn-sm btn-white border border-end-0" onclick="restoreBackup('<%= file %>')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Restore
                      </button>
                      <button class="btn btn-sm btn-white border border-end-0" onclick="renameBackup('<%= file %>')" title="Rename">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <button class="btn btn-sm btn-outline-danger border" onclick="deleteBackup('<%= file %>')">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="3" class="text-center py-5 text-muted">
                  <i class="bi bi-shield-slash fs-2 d-block mb-2"></i> No backups found.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    
    <div class="mt-4 p-3 bg-primary bg-opacity-10 rounded border border-primary border-opacity-25">
       <div class="d-flex gap-3 align-items-center">
         <i class="bi bi-info-circle-fill text-primary fs-4"></i>
         <div class="small">
           <strong>Pro Tip:</strong> Backups are stored as <code>.json</code> files in the <code>/backups</code> folder. You can manually download or upload these files to transfer your database to another environment.
         </div>
       </div>
    </div>
  </div>
</div>

<style>
  .btn-white { background: white; color: #445566; }
  .btn-white:hover { background: #f8f9fa; }
</style>

<script>
  async function restoreBackup(filename) {
    if (!confirm(`CAUTION: Restoring "${filename}" will overwrite all current data. Are you absolutely sure?`)) return;
    
    const btn = event.currentTarget;
    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Restoring...';

    try {
      const response = await fetch('/admin/backups/restore', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename })
      });
      
      if (response.ok) {
        alert('System restored successfully.');
        location.href = '/admin';
      } else {
        const err = await response.json();
        alert('Restore failed: ' + err.error);
      }
    } catch (e) { alert('Network error.'); }
    finally { btn.disabled = false; btn.innerHTML = originalHtml; }
  }

  async function renameBackup(oldFilename) {
    const newName = prompt('New name for this backup (without .json):', oldFilename.replace('.json', ''));
    if (!newName || newName.trim() === '') return;
    try {
      const res = await fetch('/admin/backups/rename', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ oldFilename, newFilename: newName.trim() })
      });
      if (res.ok) location.reload();
      else { const err = await res.json(); alert('Rename failed: ' + err.error); }
    } catch (e) { alert('Network error.'); }
  }

  async function deleteBackup(filename) {
    if (!confirm(`Delete backup file "${filename}" permanently?`)) return;
    try {
      const res = await fetch('/admin/backups/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename })
      });
      if (res.ok) location.reload();
    } catch (e) { alert('Network error.'); }
  }
</script>

<%- include('partials/admin-footer') %>
