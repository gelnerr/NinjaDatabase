<%- include('partials/admin-header', { title: 'Ninja Bucks Settings', active: 'nb-editor' }) %>

<div class="page-header">
  <h2 class="page-title">Ninja Bucks Configuration</h2>
  <p class="text-muted">Manage the link between your Google Sheets and the lobby dashboard.</p>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="admin-card p-4 p-md-5 shadow-sm mb-4">
      <form action="/admin/update-ninjabucks-config" method="POST">
        <h5 class="fw-bold mb-4"><i class="bi bi-google text-primary me-2"></i> Google Sheets Integration</h5>
        
        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">
            Display Spreadsheet ID
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 ms-2" style="font-size:0.65rem;">Leaderboard read</span>
          </label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-eye-fill"></i></span>
            <input type="text" name="spreadsheetId" class="form-control border-start-0" value="<%= data.spreadsheetId %>" placeholder="e.g. 1aBC...xyz">
          </div>
          <div class="form-text mt-1">The spreadsheet with your <strong>Ninja Bucks</strong> leaderboard sheet. Used to display scores on the public page.</div>
        </div>

        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">
            Operational Spreadsheet ID
            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 ms-2" style="font-size:0.65rem;">Write sync</span>
          </label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-pencil-fill"></i></span>
            <input type="text" name="mainSpreadsheetId" class="form-control border-start-0" value="<%= data.mainSpreadsheetId || '' %>" placeholder="e.g. 1xYZ...abc">
          </div>
          <div class="form-text mt-1">The spreadsheet with <strong>NB Log, data, Progress, Progress Log</strong> sheets. Website changes sync here.</div>
        </div>

        <div class="mb-5">
          <label class="form-label small fw-bold text-uppercase text-muted">Leaderboard Range</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-grid-3x3"></i></span>
            <input type="text" name="spreadsheetRange" class="form-control border-start-0" value="<%= data.spreadsheetRange || 'Ninja Bucks!A2:C150' %>" placeholder="e.g. Ninja Bucks!A2:C150">
          </div>
          <div class="form-text mt-1">Range within the Display spreadsheet. Format: <code>SheetName!A2:C150</code></div>
        </div>

        <div class="d-grid">
          <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow">
            <i class="bi bi-save2-fill me-2"></i> Update Configuration
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="admin-card p-4 shadow-sm bg-light mb-4">
      <h5 class="fw-bold mb-3">Sync Preview</h5>
      <p class="small text-muted mb-4">Current data will be pulled from the specified range and displayed on the leaderboard.</p>

      <div class="p-3 bg-white border rounded-3 mb-4">
        <span class="small fw-bold">Leaderboard columns required:</span>
        <ol class="small text-muted mb-0 mt-1">
          <li>Ninja Name (Column A)</li>
          <li>Total Bucks (Column B)</li>
          <li>Monthly Bucks (Column C)</li>
        </ol>
      </div>

      <div class="d-grid">
         <a href="/ninjabucks" target="_blank" class="btn btn-outline-secondary rounded-pill">
           <i class="bi bi-box-arrow-up-right me-2"></i> View Live Leaderboard
         </a>
      </div>
    </div>

    <!-- Sheets Connection Tester -->
    <div class="admin-card p-4 shadow-sm mb-4">
      <h5 class="fw-bold mb-1"><i class="bi bi-plug-fill me-2 text-primary"></i>Sheets Read Connection</h5>
      <p class="small text-muted mb-3">Tests credentials, spreadsheet access, and required sheet names.</p>
      <div class="d-grid mb-3">
        <button class="btn btn-primary rounded-pill fw-bold" onclick="runTest()" id="testBtn">
          <i class="bi bi-play-circle-fill me-2"></i> Run Connection Test
        </button>
      </div>
      <div id="testResults" style="display:none;">
        <div id="testList" class="mb-2"></div>
        <div id="testSummary" class="small fw-bold mt-3 p-3 rounded-3"></div>
      </div>
    </div>

    <!-- Webhook Tester -->
    <div class="admin-card p-4 shadow-sm">
      <h5 class="fw-bold mb-1"><i class="bi bi-arrow-left-right me-2 text-success"></i>Sheets→Website Webhook</h5>
      <p class="small text-muted mb-3">Fires the exact same logic the Apps Script triggers. Confirms the secret is set and MongoDB writes work.</p>
      <div class="d-grid mb-3">
        <button class="btn btn-success rounded-pill fw-bold" onclick="runWebhookTest()" id="webhookTestBtn">
          <i class="bi bi-lightning-charge-fill me-2"></i> Simulate Webhook Call
        </button>
      </div>
      <div id="webhookResults" style="display:none;">
        <div id="webhookList" class="mb-2"></div>
        <div id="webhookSummary" class="small fw-bold mt-3 p-3 rounded-3"></div>
      </div>
    </div>

    <!-- One-time Formula Repair -->
    <div class="admin-card p-4 shadow-sm mt-4">
      <h5 class="fw-bold mb-1"><i class="bi bi-wrench-adjustable-circle-fill me-2 text-warning"></i>Repair Total Column Formulas</h5>
      <p class="small text-muted mb-3">
        Scans <code>data!B2:B</code> for rows that are a literal number instead of a formula (damage from the old bug).
        For each one found, backfills column F so that restoring <code>=SUM(F{row}:{row})</code> reproduces that ninja's
        current MongoDB total exactly — so nobody's total drops back to a stale pre-bug value. Already-healthy rows are
        left completely untouched. Row 1 is never touched.
      </p>
      <div class="d-grid mb-3">
        <button class="btn btn-warning rounded-pill fw-bold" onclick="runFormulaRepair()" id="repairBtn">
          <i class="bi bi-tools me-2"></i> Repair Column B Formulas
        </button>
      </div>
      <div id="repairResults" style="display:none;">
        <div id="repairList" class="mb-2" style="max-height: 300px; overflow-y: auto;"></div>
        <div id="repairSummary" class="small fw-bold mt-2 p-3 rounded-3"></div>
      </div>
    </div>
  </div>
</div>

<script>
  async function runWebhookTest() {
    const btn = document.getElementById('webhookTestBtn');
    const results = document.getElementById('webhookResults');
    const list = document.getElementById('webhookList');
    const summary = document.getElementById('webhookSummary');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Testing...';
    results.style.display = 'none';

    try {
      const res = await fetch('/admin/test-webhook', { method: 'POST' });
      const data = await res.json();

      list.innerHTML = data.steps.map(s => `
        <div class="d-flex align-items-start gap-2 mb-2">
          <span class="mt-1">${s.ok ? '✅' : '❌'}</span>
          <div>
            <div class="small fw-bold ${s.ok ? 'text-dark' : 'text-danger'}">${s.label}</div>
            ${s.detail ? `<div class="small text-muted" style="word-break:break-all;">${s.detail}</div>` : ''}
          </div>
        </div>
      `).join('');

      if (data.success) {
        summary.className = 'small fw-bold mt-3 p-3 rounded-3 bg-success bg-opacity-10 text-success border border-success border-opacity-25';
        summary.innerHTML = `✅ Webhook logic works. A +1 NB entry for <strong>${data.testedNinja}</strong> was just written to NB Log — go check it now to confirm.`;
      } else {
        const failed = data.steps.find(s => !s.ok);
        summary.className = 'small fw-bold mt-3 p-3 rounded-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25';
        summary.textContent = `❌ Failed at: "${failed?.label}". See detail above.`;
      }
      results.style.display = 'block';
    } catch(e) {
      list.innerHTML = `<div class="text-danger small">Network error: ${e.message}</div>`;
      results.style.display = 'block';
    }

    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-lightning-charge-fill me-2"></i> Simulate Webhook Call';
  }

  async function runFormulaRepair() {
    if (!confirm('This scans column B for corrupted (non-formula) rows, backfills column F so the restored formula matches each ninja\'s current MongoDB total, then restores the formula. Continue?')) return;

    const btn = document.getElementById('repairBtn');
    const results = document.getElementById('repairResults');
    const list = document.getElementById('repairList');
    const summary = document.getElementById('repairSummary');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Repairing...';
    results.style.display = 'none';
    list.innerHTML = '';

    try {
      const res = await fetch('/admin/repair-data-formulas', { method: 'POST' });
      const data = await res.json();

      if (data.success) {
        list.innerHTML = (data.fixed || []).map(f => `
          <div class="d-flex justify-content-between small border-bottom py-1">
            <span>✅ <strong>${f.name}</strong> (row ${f.row})</span>
            <span class="text-muted">F set to ${f.newF} → total ${f.mongoTotal}</span>
          </div>
        `).join('') + (data.skipped || []).map(s => `
          <div class="d-flex justify-content-between small border-bottom py-1 text-danger">
            <span>⚠️ <strong>${s.name}</strong> (row ${s.row})</span>
            <span>${s.reason}</span>
          </div>
        `).join('');

        summary.className = 'small fw-bold mt-2 p-3 rounded-3 bg-success bg-opacity-10 text-success border border-success border-opacity-25';
        summary.textContent = data.rowsFixed === 0
          ? '✅ No corrupted rows found — column B is already all formulas.'
          : `✅ Fixed ${data.rowsFixed} row(s)${data.skipped?.length ? `, skipped ${data.skipped.length}` : ''}.`;
      } else {
        summary.className = 'small fw-bold mt-2 p-3 rounded-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25';
        summary.textContent = `❌ ${data.error}`;
      }
      results.style.display = 'block';
    } catch(e) {
      summary.className = 'small fw-bold mt-2 p-3 rounded-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25';
      summary.textContent = `❌ Network error: ${e.message}`;
      results.style.display = 'block';
    }

    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-tools me-2"></i> Repair Column B Formulas';
  }

  async function runTest() {
    const btn = document.getElementById('testBtn');
    const results = document.getElementById('testResults');
    const list = document.getElementById('testList');
    const summary = document.getElementById('testSummary');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Testing...';
    results.style.display = 'none';

    try {
      const res = await fetch('/admin/test-sheets');
      const data = await res.json();

      list.innerHTML = data.steps.map(s => `
        <div class="d-flex align-items-start gap-2 mb-2">
          <span class="mt-1" style="font-size:1rem;">${s.ok ? '✅' : '❌'}</span>
          <div>
            <div class="small fw-bold ${s.ok ? 'text-dark' : 'text-danger'}">${s.label}</div>
            ${s.detail ? `<div class="small text-muted" style="word-break:break-all;">${s.detail}</div>` : ''}
          </div>
        </div>
      `).join('');

      if (data.success) {
        summary.className = 'small fw-bold mt-3 p-3 rounded-3 bg-success bg-opacity-10 text-success border border-success border-opacity-25';
        summary.textContent = '✅ All checks passed — website → Sheets sync is fully operational.';
      } else {
        const failed = data.steps.find(s => !s.ok);
        summary.className = 'small fw-bold mt-3 p-3 rounded-3 bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25';
        summary.textContent = `❌ Failed at: "${failed?.label}". See detail above.`;
      }

      results.style.display = 'block';
    } catch(e) {
      list.innerHTML = `<div class="text-danger small">Network error: ${e.message}</div>`;
      results.style.display = 'block';
    }

    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-play-circle-fill me-2"></i> Run Connection Test';
  }
</script>

<%- include('partials/admin-footer') %>
