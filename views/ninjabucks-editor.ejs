<%- include('partials/admin-header', { title: 'Settings', active: 'editor' }) %>

<div class="page-header">
  <h2 class="page-title">Ninja Bucks Configuration</h2>
  <p class="text-muted">Manage the link between your Google Sheets and the lobby dashboard.</p>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="admin-card p-4 p-md-5 shadow-sm mb-4">
      <form action="/admin/update-ninjabucks-config" method="POST">
        <h5 class="fw-bold mb-4"><i class="bi bi-google text-primary me-2"></i> Google Sheets Integration</h5>
        
        <div class="mb-4">
          <label class="form-label small fw-bold text-uppercase text-muted">Spreadsheet ID</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-link-45deg"></i></span>
            <input type="text" name="spreadsheetId" class="form-control border-start-0" value="<%= data.spreadsheetId %>" placeholder="e.g. 1aBC...xyz" required>
          </div>
          <div class="form-text mt-2">Found in the URL of your Google Sheet.</div>
        </div>

        <div class="mb-5">
          <label class="form-label small fw-bold text-uppercase text-muted">Spreadsheet Range</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-grid-3x3"></i></span>
            <input type="text" name="spreadsheetRange" class="form-control border-start-0" value="<%= data.spreadsheetRange || 'Ninja Bucks!A2:C150' %>" placeholder="e.g. Sheet1!A2:C50" required>
          </div>
          <div class="form-text mt-2">Format: <code>'Sheet Name'!A2:C150</code></div>
        </div>

        <div class="d-grid">
          <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow">
            <i class="bi bi-save2-fill me-2"></i> Update Configuration
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="admin-card p-4 shadow-sm bg-light">
      <h5 class="fw-bold mb-3">Sync Preview</h5>
      <p class="small text-muted mb-4">Current data will be pulled from the specified range and displayed on the leaderboard.</p>
      
      <div class="p-3 bg-white border rounded-3 mb-4">
        <div class="d-flex justify-content-between mb-1">
          <span class="small fw-bold">Columns Required:</span>
        </div>
        <ol class="small text-muted mb-0">
          <li>Ninja Name (Column A)</li>
          <li>Total Bucks (Column B)</li>
          <li>Monthly Bucks (Column C)</li>
        </ol>
      </div>

      <div class="d-grid">
         <a href="/ninjabucks" target="_blank" class="btn btn-outline-secondary rounded-pill">
           <i class="bi bi-box-arrow-up-right me-2"></i> View Live Leaderboard
         </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
