<%- include('partials/admin-header', { title: 'Admin Home', active: 'dashboard' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">Sensei Dashboard</h2>
    <p class="text-muted mb-0">System status and quick navigation.</p>
  </div>
  <div class="d-flex gap-2">
    <div class="btn-group me-2 shadow-sm rounded-pill" role="group">
      <button class="btn btn-outline-primary <%= viewType === 'Create' ? 'active fw-bold' : '' %>" style="border-radius: 50px 0 0 50px;" onclick="setAdminView('Create')">Create Kids</button>
      <button class="btn btn-outline-primary <%= viewType === 'Junior' ? 'active fw-bold' : '' %>" style="border-radius: 0 50px 50px 0;" onclick="setAdminView('Junior')">Junior Kids</button>
    </div>
    <a href="/admin/add-ninja" class="btn btn-primary rounded-pill px-4 shadow-sm">
      <i class="bi bi-person-plus-fill me-2"></i> Add Ninja
    </a>
    <div class="dropdown">
      <button class="btn btn-outline-primary dropdown-toggle rounded-pill px-4" type="button" data-bs-toggle="dropdown">
        <i class="bi bi-database-fill-up me-1"></i> Data Migration
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
        <li><a class="dropdown-item py-2" href="#" onclick="migrateDatabase(false)"><i class="bi bi-arrow-repeat me-2"></i> Sync Latest Data</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger py-2" href="#" onclick="migrateDatabase(true)"><i class="bi bi-trash3 me-2"></i> Fresh Start (Wipe & Import)</a></li>
      </ul>
    </div>
  </div>
</div>

<style>
  .nav-card {
    background: white; border-radius: 16px; border: 1px solid var(--cn-border);
    padding: 24px; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%; display: flex; flex-direction: column; text-decoration: none !important; color: inherit;
  }
  .nav-card:hover { border-color: var(--cn-blue); transform: translateY(-4px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
  .icon-box {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; margin-bottom: 20px;
  }
  .ib-blue { background: #e8f4fb; color: var(--cn-blue); }
  .ib-green { background: #e6f6f4; color: #1a7a72; }
  .ib-amber { background: #fef9e7; color: #9a6e00; }
  .ib-purple { background: #f3e5f5; color: #662d91; }
  
  .nav-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: var(--cn-dark); }
  .nav-card p { font-size: 14px; color: #6b7280; margin-bottom: 0; line-height: 1.5; }
  
  .boss-banner {
    background: linear-gradient(135deg, #231f20 0%, #3a3536 100%);
    border-radius: 20px; padding: 30px; color: white; margin-bottom: 40px;
    border: 1px solid rgba(255,255,255,0.1); position: relative; overflow: hidden;
  }
  .boss-banner::after {
    content: 'BOSS'; position: absolute; right: -20px; bottom: -30px;
    font-size: 120px; font-weight: 900; color: rgba(255,255,255,0.03); pointer-events: none;
  }
  .hp-bar-outer { background: rgba(255,255,255,0.1); border-radius: 10px; height: 12px; margin: 15px 0; overflow: hidden; }
  .hp-bar-inner { height: 100%; border-radius: 10px; background: var(--cn-blue); transition: width 1s ease; }
</style>

<!-- Boss Battle Quick Status -->
<% if (data.bossActive) { %>
<div class="boss-banner shadow-sm mb-4">
  <div class="row align-items-center">
    <div class="col-md-8">
      <div class="d-flex align-items-center gap-3 mb-2">
        <h4 class="mb-0 fw-bold"><%= data.bossName %></h4>
        <span class="badge bg-primary px-3">LIVE BATTLE</span>
      </div>
      <div class="hp-bar-outer"><div class="hp-bar-inner" style="width: <%= data.bossMaxHP > 0 ? Math.round((data.bossHP / data.bossMaxHP) * 100) : 0 %>%"></div></div>
      <div class="d-flex justify-content-between small opacity-75">
        <span>Current Health</span>
        <span><%= data.bossHP.toLocaleString() %> / <%= data.bossMaxHP.toLocaleString() %> HP (<%= data.bossMaxHP > 0 ? Math.round((data.bossHP / data.bossMaxHP) * 100) : 0 %>%)</span>
      </div>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
      <a href="/admin/boss-battle" class="btn btn-outline-light px-4 border-2 fw-bold rounded-pill">Manage Event</a>
    </div>
  </div>
</div>
<% } %>

<div class="row g-4">
  <% if (viewType === 'Create') { %>
  <div class="col-md-4">
    <a href="/admin/dashboard-editor" class="nav-card">
      <div class="icon-box ib-green"><i class="bi bi-pencil-square"></i></div>
      <h3>Dashboard Editor</h3>
      <p>Configure events, activities, NOTM, and lobby display.</p>
    </a>
  </div>
  <% } %>
  <div class="col-md-4">
    <a href="/admin/ninja-bucks-award" class="nav-card">
      <div class="icon-box ib-amber"><i class="bi bi-coin"></i></div>
      <h3>Manage Ninja Bucks</h3>
      <p>Award or remove bucks for achievements, birthdays, and more.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/buttons" class="nav-card">
      <div class="icon-box ib-blue"><i class="bi bi-lightning-charge"></i></div>
      <h3>Quick Controls</h3>
      <p>Fast rewards and macros for session management.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/master-data" class="nav-card">
      <div class="icon-box ib-purple"><i class="bi bi-database-fill"></i></div>
      <h3>Ninja Master Data</h3>
      <p>View and manage the full database of ninjas.</p>
    </a>
  </div>
  <% if (viewType === 'Create') { %>
  <div class="col-md-4">
    <a href="/admin/progress-matrix" class="nav-card">
      <div class="icon-box ib-purple"><i class="bi bi-trophy-fill"></i></div>
      <h3>Belt Totem</h3>
      <p>See current distribution across all belt ranks.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/update-progress" class="nav-card">
      <div class="icon-box ib-blue"><i class="bi bi-graph-up-arrow"></i></div>
      <h3>Update Progress</h3>
      <p>Log belt tests and rank advancements for ninjas.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/progress-log" class="nav-card">
      <div class="icon-box ib-purple"><i class="bi bi-clipboard-pulse"></i></div>
      <h3>Advancement History</h3>
      <p>View chronological history of all belt level-ups.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/shop-editor" class="nav-card">
      <div class="icon-box ib-green"><i class="bi bi-cart4"></i></div>
      <h3>Shop Management</h3>
      <p>Edit items, prices, and stock in the Ninja Shop.</p>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/admin/backups" class="nav-card">
      <div class="icon-box ib-blue"><i class="bi bi-shield-lock-fill"></i></div>
      <h3>Backups & Recovery</h3>
      <p>Manage database snapshots and restore points.</p>
    </a>
  </div>
  <% } else { %>
  <div class="col-md-4">
    <a href="/admin/graduate-junior" class="nav-card">
      <div class="icon-box ib-amber"><i class="bi bi-mortarboard-fill"></i></div>
      <h3>Graduate Ninja</h3>
      <p>Graduate a Junior ninja to the Create program and assign a White Belt.</p>
    </a>
  </div>
  <% } %>
</div>

<script>
  async function setAdminView(view) {
    await fetch('/admin/set-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ view })
    });
    location.reload();
  }

  async function migrateDatabase(wipe = false) {
    const actionText = wipe ? 'WIPE all current data and re-import' : 'SYNC and update existing data';
    if (!confirm(`Are you sure you want to ${actionText}? A backup will be created automatically.`)) return;
    
    try {
      const response = await fetch('/admin/migrate-database', { 
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ wipe })
      });
      const result = await response.json();
      
      if (result.success) {
        const modal = new bootstrap.Modal(document.getElementById('migrationModal'));
        modal.show();
        pollMigrationStatus();
      } else {
        alert('Failed to start migration: ' + result.error);
      }
    } catch (error) {
      alert('Network Error starting migration.');
    }
  }

  async function pollMigrationStatus() {
    const bar = document.getElementById('migrationProgressBar');
    const msg = document.getElementById('migrationStatusMsg');
    
    const interval = setInterval(async () => {
      try {
        const response = await fetch('/admin/migration-status');
        const status = await response.json();
        
        bar.style.width = status.progress + '%';
        msg.textContent = status.message;
        
        if (status.error) {
          clearInterval(interval);
          alert('Migration Error: ' + status.error);
        } else if (!status.active && status.progress === 100) {
          clearInterval(interval);
          setTimeout(() => {
            alert(`Migration Complete!\nNinjas: ${status.results?.ninjas || 0}\nLogs: ${status.results?.logs || 0}`);
            location.reload();
          }, 500);
        }
      } catch (e) { console.error('Polling error', e); }
    }, 1000);
  }
</script>

<div class="modal fade" id="migrationModal" data-bs-backdrop="static" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-body p-5">
        <div class="text-center mb-4">
          <div class="spinner-border text-primary mb-3" role="status"></div>
          <h4 class="fw-bold">Updating Database</h4>
          <p id="migrationStatusMsg" class="text-muted">Initializing migration engine...</p>
        </div>
        <div class="progress" style="height: 12px; border-radius: 10px; background: #eee;">
          <div id="migrationProgressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 0%; border-radius: 10px;"></div>
        </div>
        <p class="text-muted small mt-4 text-center">Processing spreadsheets. Please wait...</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
