<body>

<% if (theme === 'undertale') { %>
  <!-- Player SOUL — pixel-art red heart that beats at the bottom of the screen -->
  <div id="ut-player-soul">
    <div class="ut-ph ut-ph-lg" style="--sc:#ff0000;"></div>
  </div>

  <!-- Rotating save point star -->
  <div id="ut-savepoint">✦</div>

  <script>
    /* Spawn random SOUL hearts that float up the screen */
    const UT_SOULS = [
      { char: '❤', color: '#ff0000' }, // Determination (red)
      { char: '❤', color: '#ff8c00' }, // Bravery (orange)
      { char: '❤', color: '#ffff00' }, // Justice (yellow)
      { char: '❤', color: '#00c000' }, // Kindness (green)
      { char: '❤', color: '#4040ff' }, // Integrity (blue)
      { char: '❤', color: '#c040ff' }, // Perseverance (purple)
      { char: '❤', color: '#00ffff' }, // Patience (cyan)
    ];

    /* Scatter a small handful of pixel stars on load */
    for (let i = 0; i < 28; i++) {
      const star = document.createElement('span');
      star.className = 'ut-star';
      star.textContent = ['✦','✧','·','*'][Math.floor(Math.random()*4)];
      star.style.left = Math.random() * 100 + 'vw';
      star.style.top  = Math.random() * 100 + 'vh';
      star.style.animationDuration = (2 + Math.random() * 4) + 's';
      star.style.animationDelay    = (Math.random() * 4) + 's';
      star.style.opacity = 0.3 + Math.random() * 0.5;
      document.body.appendChild(star);
    }

    function spawnSoul() {
      const soul = UT_SOULS[Math.floor(Math.random() * UT_SOULS.length)];

      // Container handles the float animation + position
      const wrapper = document.createElement('div');
      wrapper.className = 'ut-soul';
      // Small heart is 4px/px × 7 cols = 28px wide; base div at col 1 = 4px from edge → offset -4px to left-align
      wrapper.style.left = (5 + Math.random() * 88) + 'vw';
      const drift = (Math.random() - 0.5) * 140;
      wrapper.style.setProperty('--drift', drift + 'px');
      const dur = 7 + Math.random() * 8;
      wrapper.style.animationDuration = dur + 's';
      wrapper.style.filter = `drop-shadow(0 0 5px ${soul.color})`;

      // Pixel-art heart
      const heart = document.createElement('div');
      heart.className = 'ut-ph ut-ph-sm';
      heart.style.setProperty('--sc', soul.color);
      wrapper.appendChild(heart);

      document.body.appendChild(wrapper);
      setTimeout(() => wrapper.remove(), dur * 1000);
    }

    /* Spawn a soul every 1.4 seconds */
    spawnSoul();
    setInterval(spawnSoul, 1400);
  </script>
<% } %>

