  <style>
    @keyframes bossBreathing {
      0%, 100% { transform: scale(1); filter: drop-shadow(0 0 40px rgba(230,57,70,0.5)); }
      50% { transform: scale(1.04); filter: drop-shadow(0 0 60px rgba(230,57,70,0.9)); }
    }
    .boss-breathing { animation: bossBreathing 3s ease-in-out infinite; }
  </style>

  <script>
    const BOSS_HP = <%= bossHP %>;
    const BOSS_MAX_HP = <%= bossMaxHP %>;

    function openBossOverlay() {
      const overlay = document.getElementById('bossOverlay');
      if (!overlay) return;
      overlay.style.display = 'block';
      overlay.style.opacity = '0';

      // Phase 1: fade in black
      requestAnimationFrame(() => {
        overlay.style.transition = 'opacity 0.5s ease';
        overlay.style.opacity = '1';
      });

      // Phase 2: boss image fades in
      setTimeout(() => {
        const img = document.getElementById('bossOverlayImg');
        img.style.opacity = '1';
        img.style.transform = 'scale(1)';
        setTimeout(() => img.classList.add('boss-breathing'), 1000);
      }, 600);

      // Phase 3: boss info fades in + HP bar animates
      setTimeout(() => {
        const info = document.getElementById('bossOverlayInfo');
        info.style.opacity = '1';
        info.style.transform = 'translateY(0)';
        const hpPct = BOSS_MAX_HP > 0 ? Math.round((BOSS_HP / BOSS_MAX_HP) * 100) : 0;
        setTimeout(() => {
          document.getElementById('bossOverlayHpBar').style.width = hpPct + '%';
        }, 100);
      }, 1400);

      // Phase 4: side panels slide in
      setTimeout(() => {
        document.getElementById('bossLeftPanel').style.opacity = '1';
        document.getElementById('bossLeftPanel').style.transform = 'translateX(0)';
        document.getElementById('bossRightPanel').style.opacity = '1';
        document.getElementById('bossRightPanel').style.transform = 'translateX(0)';
      }, 2000);
    }

    function closeBossOverlay() {
      const overlay = document.getElementById('bossOverlay');
      if (!overlay) return;
      overlay.style.transition = 'opacity 0.4s ease';
      overlay.style.opacity = '0';
      setTimeout(() => {
        overlay.style.display = 'none';
        // Reset for next open
        const img = document.getElementById('bossOverlayImg');
        img.classList.remove('boss-breathing');
        img.style.opacity = '0';
        img.style.transform = 'scale(0.85)';
        document.getElementById('bossOverlayInfo').style.opacity = '0';
        document.getElementById('bossOverlayInfo').style.transform = 'translateY(20px)';
        document.getElementById('bossOverlayHpBar').style.width = '0%';
        document.getElementById('bossLeftPanel').style.opacity = '0';
        document.getElementById('bossLeftPanel').style.transform = 'translateX(-60px)';
        document.getElementById('bossRightPanel').style.opacity = '0';
        document.getElementById('bossRightPanel').style.transform = 'translateX(60px)';
      }, 400);
    }
  </script>

  <script>
    function updateSessionTimer() {
      const now = new Date();
      const mins = now.getMinutes();
      const secs = now.getSeconds();
      const timerContainer = document.getElementById('timer-container');
      const timerBar = document.getElementById('timer-bar');
      const timerText = document.getElementById('timer-text');
      
      if (!timerContainer || !timerBar || !timerText) return;

      if (mins < 45) {
        // Coding phase (0-45 mins)
        const totalSecsElapsed = (mins * 60) + secs;
        const totalSecsInPhase = 45 * 60;
        const percent = (totalSecsElapsed / totalSecsInPhase) * 100;
        
        const secsLeft = totalSecsInPhase - totalSecsElapsed;
        const minsLeft = Math.floor(secsLeft / 60);
        const displaySecs = (secsLeft % 60).toString().padStart(2, '0');
        
        timerBar.style.width = percent + '%';
        timerText.innerText = `${minsLeft}:${displaySecs} LEFT FOR CODING!`;
        timerContainer.classList.remove('phase-activity');
      } else {
        // Activity phase (45-60 mins)
        timerBar.style.width = '100%';
        timerText.innerText = 'TIME FOR DAILY ACTIVITY!';
        timerContainer.classList.add('phase-activity');
      }
    }

    function updateClock() {
      const now = new Date();
      document.getElementById('clock').innerText = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      updateSessionTimer();
    }
    setInterval(updateClock, 1000);
    updateClock();
  </script>
</body>

</html>