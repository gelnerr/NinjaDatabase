<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Code Ninjas - Ninja Dashboard</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/icons/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <% if (theme==='space' ) { %>
    <link href="https://fonts.googleapis.com/css2?family=Luckiest+Guy&family=Fredoka:wght@400;600;700&display=swap"
      rel="stylesheet">
    <style>
      :root {
        --space-purple: #6D5BBA;
        --space-cyan: #00D2FF;
        --space-yellow: #FFD93D;
        --space-blue: #4D96FF;
        --space-dark: #1A1A2E;
        --card-bg: rgba(255, 255, 255, 0.95);
        --text-main: var(--space-dark);
        --text-muted: #666;
      }

      body {
        background-color: var(--space-dark);
        background-image: radial-gradient(white, rgba(255, 255, 255, .2) 2px, transparent 40px), radial-gradient(white, rgba(255, 255, 255, .15) 1px, transparent 30px), radial-gradient(rgba(109, 91, 186, 0.2) 0%, transparent 70%);
        background-size: 550px 550px, 350px 350px, 100% 100%;
        color: var(--text-main);
        font-family: 'Fredoka', sans-serif;
      }

      .header {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        border: 3px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        color: white;
      }

      .kid-card {
        background: var(--card-bg);
        border: 6px solid var(--space-purple);
        border-radius: 30px;
        box-shadow: 0 10px 0px var(--space-purple);
        color: var(--text-main);
      }

      .kid-card h2 {
        color: var(--space-cyan);
        font-family: 'Luckiest Guy';
        -webkit-text-stroke: 1px var(--space-dark);
      }

      .activity-item {
        background: #eefbff;
        border-radius: 20px;
        border: 2px dashed var(--space-blue);
      }

      .activity-info a {
        color: var(--space-blue);
        background: white;
        box-shadow: 0 2px 0 var(--space-blue);
      }

      .event-date {
        background: var(--space-cyan);
        color: var(--space-dark);
        border-radius: 10px;
      }

      .ninja-month-img {
        border: 5px solid var(--space-yellow);
        border-radius: 50%;
      }

      .vote-btn {
        background: var(--space-yellow);
        color: var(--space-dark);
        font-family: 'Luckiest Guy';
        border-radius: 50px;
        box-shadow: 0 6px 0px #c9a500;
      }

      #clock {
        font-family: 'Luckiest Guy';
        color: white;
        text-shadow: 3px 3px 0px var(--space-purple);
      }

      @keyframes float {

        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
        }

        50% {
          transform: translateY(-15px) rotate(2deg);
        }
      }

      .animated {
        animation: float 6s ease-in-out infinite;
      }

      .text-muted-theme {
        color: var(--text-muted);
      }

      .timer-container {
        height: 40px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        border: 2px solid var(--space-purple);
        overflow: hidden;
        position: relative;
        flex-grow: 1;
        margin: 0 20px;
      }
      .timer-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--space-cyan), var(--space-blue));
        transition: width 1s linear;
      }
      .timer-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-family: 'Luckiest Guy';
        white-space: nowrap;
        text-shadow: 2px 2px 0px var(--space-purple);
        z-index: 2;
        width: 100%;
        text-align: center;
      }
      .phase-activity .timer-bar {
        background: var(--space-yellow);
        animation: pulse-space 1.5s infinite;
      }
      @keyframes pulse-space {
        0% { opacity: 1; }
        50% { opacity: 0.6; }
        100% { opacity: 1; }
      }
    </style>
    <% } else if (theme==='cyber' ) { %>
      <link
        href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;600;800&display=swap"
        rel="stylesheet">
      <style>
        :root {
          --tech-orange: #FF9F1C;
          --tech-yellow: #FFBF00;
          --tech-green: #2EC4B6;
          --tech-bg: #011627;
          --text-main: #FDFFFC;
          --text-muted: #8899aa;
        }

        body {
          background-color: var(--tech-bg);
          background-image: linear-gradient(rgba(46, 196, 182, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(46, 196, 182, 0.05) 1px, transparent 1px);
          background-size: 30px 30px;
          color: var(--text-main);
          font-family: 'Exo 2', sans-serif;
        }

        .header {
          background: rgba(255, 255, 255, 0.03);
          border-bottom: 2px solid var(--tech-green);
        }

        .kid-card {
          background: rgba(1, 22, 39, 0.85);
          border: 1px solid rgba(46, 196, 182, 0.3);
          border-left: 4px solid var(--tech-orange);
          backdrop-filter: blur(10px);
          box-shadow: 0 0 15px rgba(255, 159, 28, 0.1);
          color: var(--text-main);
        }

        .kid-card h2 {
          color: var(--tech-yellow);
          font-family: 'Orbitron';
          border-bottom: 1px solid rgba(255, 191, 0, 0.2);
          padding-bottom: 10px;
        }

        .activity-item {
          background: rgba(255, 255, 255, 0.05);
          border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .activity-info a {
          color: var(--tech-orange);
          font-family: 'Orbitron';
          text-transform: uppercase;
          font-weight: bold;
        }

        .event-date {
          color: var(--tech-green);
          font-family: 'Orbitron';
          font-weight: bold;
        }

        .ninja-month-img {
          border: 2px solid var(--tech-yellow);
          clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
        }

        .vote-btn {
          border: 2px solid var(--tech-orange);
          color: var(--tech-orange);
          font-family: 'Orbitron';
          clip-path: polygon(10% 0, 100% 0, 90% 100%, 0 100%);
          transition: all 0.2s;
          background: transparent;
        }

        .vote-btn:hover {
          background: var(--tech-orange);
          color: var(--tech-bg);
        }

        #clock {
          font-family: 'Orbitron';
          color: var(--tech-yellow);
          text-shadow: 0 0 10px rgba(255, 191, 0, 0.3);
        }

        @keyframes pulse {

          0%,
          100% {
            transform: scale(1);
            opacity: 0.8;
          }

          50% {
            transform: scale(1.02);
            opacity: 1;
          }
        }

        .animated {
          animation: pulse 4s ease-in-out infinite;
        }

        .text-muted-theme {
          color: var(--text-muted);
        }

        .activity-info h3 {
          color: var(--text-main);
        }

        .timer-container {
          height: 35px;
          background: rgba(0, 0, 0, 0.3);
          border: 1px solid var(--tech-green);
          position: relative;
          flex-grow: 1;
          margin: 0 20px;
          clip-path: polygon(5px 0, 100% 0, calc(100% - 5px) 100%, 0 100%);
          overflow: hidden;
        }
        .timer-bar {
          height: 100%;
          background: var(--tech-orange);
          box-shadow: 0 0 15px var(--tech-orange);
          transition: width 1s linear;
        }
        .timer-text {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          color: var(--text-main);
          font-family: 'Orbitron';
          font-size: 0.9rem;
          font-weight: bold;
          z-index: 2;
          width: 100%;
          text-align: center;
          text-transform: uppercase;
        }
        .phase-activity .timer-bar {
          background: var(--tech-green);
          box-shadow: 0 0 20px var(--tech-green);
          animation: pulse-cyber 1s infinite;
        }
        @keyframes pulse-cyber {
          0% { filter: brightness(1); }
          50% { filter: brightness(1.5); }
          100% { filter: brightness(1); }
        }
      </style>
      <% } else if (theme === 'deepsea') { %>
        <!-- Deep Sea Theme -->
        <link href="https://fonts.googleapis.com/css2?family=Titan+One&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
        <style>
          :root {
            --sea-dark: #000d1a;
            --sea-mid: #001f3f;
            --sea-glow: #00e5ff;
            --sea-teal: #0a9396;
            --sea-biolum: #94d2bd;
            --sea-gold: #e9c46a;
          }
          @keyframes bubbleFloat {
            0% { transform: translateY(0) scale(1); opacity: 0.6; }
            100% { transform: translateY(-100vh) scale(1.3); opacity: 0; }
          }
          @keyframes seaBreath {
            0%, 100% { opacity: 0.4; transform: scaleX(1); }
            50% { opacity: 0.7; transform: scaleX(1.02); }
          }
          @keyframes biolumPulse {
            0%, 100% { box-shadow: 0 10px 0px var(--sea-teal), 0 0 20px rgba(0,229,255,0.2); }
            50% { box-shadow: 0 10px 0px var(--sea-glow), 0 0 40px rgba(0,229,255,0.5); }
          }
          body {
            background: radial-gradient(ellipse at 20% 80%, #001f3f 0%, #000d1a 60%, #000508 100%);
            background-attachment: fixed;
            color: var(--sea-biolum);
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
          }
          body::before {
            content: '';
            position: fixed; inset: 0; pointer-events: none; z-index: 0;
            background: radial-gradient(ellipse at 60% 30%, rgba(0,229,255,0.06) 0%, transparent 60%),
                        radial-gradient(ellipse at 10% 70%, rgba(10,147,150,0.08) 0%, transparent 50%);
            animation: seaBreath 8s ease-in-out infinite;
          }
          .header {
            background: rgba(0, 31, 63, 0.6);
            border: 2px solid rgba(0,229,255,0.3);
            border-radius: 20px;
            backdrop-filter: blur(12px);
            color: var(--sea-glow);
          }
          .kid-card {
            background: rgba(0, 20, 50, 0.75);
            border: 3px solid rgba(0,229,255,0.4);
            border-radius: 20px;
            box-shadow: 0 10px 0px var(--sea-teal);
            color: var(--sea-biolum);
            backdrop-filter: blur(8px);
            animation: biolumPulse 6s ease-in-out infinite;
          }
          .kid-card h2 {
            color: var(--sea-glow);
            font-family: 'Titan One';
            text-shadow: 0 0 15px rgba(0,229,255,0.7);
          }
          .activity-item { background: rgba(0,229,255,0.05); border: 1px solid rgba(0,229,255,0.2); border-radius: 15px; }
          .activity-info a { color: var(--sea-glow); font-weight: bold; }
          .event-date { background: var(--sea-teal); color: white; border-radius: 8px; padding: 2px 10px; }
          .ninja-month-img { border: 3px solid var(--sea-glow); border-radius: 50%; box-shadow: 0 0 15px rgba(0,229,255,0.4); }
          .vote-btn { background: var(--sea-teal); color: white; font-family: 'Titan One'; border-radius: 50px; }
          #clock { font-family: 'Titan One'; color: var(--sea-glow); text-shadow: 0 0 20px var(--sea-glow); }
          .animated { animation: biolumPulse 6s ease-in-out infinite; }
          .text-muted-theme { color: var(--sea-biolum); opacity: 0.6; }
          .timer-container { height: 38px; background: rgba(0,229,255,0.1); border: 2px solid rgba(0,229,255,0.3); border-radius: 20px; overflow: hidden; position: relative; flex-grow: 1; margin: 0 20px; }
          .timer-bar { height: 100%; background: linear-gradient(90deg, var(--sea-teal), var(--sea-glow)); transition: width 1s linear; }
          .timer-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: white; font-family: 'Titan One'; font-size: 0.85rem; z-index: 2; width: 100%; text-align: center; text-shadow: 0 0 8px var(--sea-glow); }
          .phase-activity .timer-bar { animation: biolumPulse 1.5s infinite; }
        </style>

      <% } else if (theme === 'undertale') { %>
        <!-- Undertale Theme -->
        <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
        <style>
          :root {
            --ut-bg: #000000; --ut-white: #ffffff;
            --ut-yellow: #ffff00; --ut-red: #ff0000;
            --ut-cyan: #00ffff; --ut-gray: #888888;
            --ut-orange: #ff8c00; --ut-blue: #4040ff;
            --ut-purple: #c040ff; --ut-green: #00c000;
          }

          /* ── Core animations ── */
          @keyframes utHeartBeat {
            0%,40%,100% { transform: scale(1);    filter: drop-shadow(0 0 6px #ff0000); }
            20%,60%     { transform: scale(1.35); filter: drop-shadow(0 0 18px #ff0000); }
          }
          @keyframes textFlicker {
            0%,89%,91%,93%,100% { opacity:1; } 90%,92% { opacity:0.6; }
          }
          @keyframes scanline {
            from { background-position: 0 0; } to { background-position: 0 80px; }
          }
          @keyframes floatSoul {
            0%   { transform: translateY(0)   translateX(0)    scale(1);    opacity: 0;   }
            5%   { opacity: 1; }
            85%  { opacity: 0.8; }
            100% { transform: translateY(-110vh) translateX(var(--drift)) scale(0.6); opacity: 0; }
          }
          @keyframes starTwinkle {
            0%,100% { opacity:0.2; transform:scale(1); }
            50%     { opacity:1;   transform:scale(1.4); }
          }
          @keyframes savepointSpin {
            from { transform: rotate(0deg); } to { transform: rotate(360deg); }
          }

          /* ── Body + background ── */
          body {
            background: #000;
            color: var(--ut-white);
            font-family: 'Press Start 2P', monospace;
            font-size: 0.75rem;
            image-rendering: pixelated;
            overflow-x: hidden;
          }
          /* CRT scanlines */
          body::after {
            content: '';
            position: fixed; inset: 0; pointer-events: none; z-index: 9998;
            background: repeating-linear-gradient(0deg, rgba(0,0,0,0.12) 0px, rgba(0,0,0,0.12) 1px, transparent 1px, transparent 4px);
            animation: scanline 4s linear infinite;
          }

          /* ── Header ── */
          .header {
            background: #000;
            border: 4px solid #fff;
            border-radius: 0;
            color: #fff;
          }

          /* ── Cards (battle dialogue boxes) ── */
          .kid-card {
            background: #000;
            border: 4px solid var(--ut-white);
            border-radius: 0;
            box-shadow: 6px 6px 0 var(--ut-white);
            color: var(--ut-white);
            position: relative;
          }
          /* Pixel corner decorations — mimics Undertale battle box corners */
          .kid-card::before, .kid-card::after {
            content: '';
            position: absolute;
            width: 8px; height: 8px;
            background: var(--ut-white);
          }
          .kid-card::before { top: -4px;  left: -4px; }
          .kid-card::after  { bottom: -4px; right: -4px; }
          .kid-card h2 {
            color: var(--ut-yellow);
            font-size: 1rem;
            text-shadow: 2px 2px 0 var(--ut-red);
            animation: textFlicker 5s infinite;
          }
          .kid-card:hover { transform: translate(-2px,-2px); box-shadow: 8px 8px 0 #fff; transition: all 0.08s steps(2); }

          /* ── Activities / items ── */
          .activity-item { background: #0a0a0a; border: 2px solid #fff; border-radius: 0; }
          .activity-info a { color: var(--ut-cyan); }
          .event-date { background: var(--ut-yellow); color: #000; font-size: 0.55rem; padding: 4px 8px; }
          .ninja-month-img { border: 4px solid #fff; border-radius: 0; image-rendering: pixelated; }
          .vote-btn { background: var(--ut-yellow); color: #000; font-size: 0.65rem; border-radius: 0; border: 3px solid #fff; box-shadow: 4px 4px 0 #fff; }

          /* ── Clock + timer ── */
          #clock { font-size: 1.3rem; color: var(--ut-cyan); text-shadow: 2px 2px 0 rgba(0,255,255,0.4); }
          .animated { animation: none; }
          .text-muted-theme { color: var(--ut-gray); }
          .timer-container { height: 52px; background: #111; border: 4px solid #fff; border-radius: 0; overflow: hidden; position: relative; flex-grow: 1; margin: 0 20px; }
          .timer-text { font-size: 0.7rem; }
          .timer-bar { height: 100%; background: var(--ut-yellow); transition: width 1s steps(30, end); }
          .timer-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: #000; font-size: 0.6rem; z-index: 2; width: 100%; text-align: center; }
          .phase-activity .timer-bar { background: var(--ut-red); animation: utHeartBeat 0.6s infinite; }

          /* ── Fun Fact typewriter prefix ── */
          .fun-fact-text::before { content: '* '; color: var(--ut-cyan); }

          /* ── Pixel-art heart base (box-shadow paints each "pixel") ── */
          /* Uses CSS custom property --sc (soul colour) so one class works for all colours */
          .ut-ph { display: block; image-rendering: pixelated; background: var(--sc, #ff0000); }

          /* Large: 10 px per pixel — the fixed player SOUL */
          .ut-ph-lg {
            width: 10px; height: 10px;
            box-shadow:
              10px 0    0 var(--sc,#f00), 30px 0    0 var(--sc,#f00), 40px 0    0 var(--sc,#f00),
              -10px 10px 0 var(--sc,#f00), 0   10px 0 var(--sc,#f00), 10px 10px 0 var(--sc,#f00),
              20px 10px 0 var(--sc,#f00), 30px 10px 0 var(--sc,#f00), 40px 10px 0 var(--sc,#f00),
              50px 10px 0 var(--sc,#f00),
              -10px 20px 0 var(--sc,#f00), 0   20px 0 var(--sc,#f00), 10px 20px 0 var(--sc,#f00),
              20px 20px 0 var(--sc,#f00), 30px 20px 0 var(--sc,#f00), 40px 20px 0 var(--sc,#f00),
              50px 20px 0 var(--sc,#f00),
              0   30px 0 var(--sc,#f00), 10px 30px 0 var(--sc,#f00), 20px 30px 0 var(--sc,#f00),
              30px 30px 0 var(--sc,#f00), 40px 30px 0 var(--sc,#f00),
              10px 40px 0 var(--sc,#f00), 20px 40px 0 var(--sc,#f00), 30px 40px 0 var(--sc,#f00),
              20px 50px 0 var(--sc,#f00);
          }

          /* Small: 4 px per pixel — the floating SOUL particles */
          .ut-ph-sm {
            width: 4px; height: 4px;
            box-shadow:
              4px 0    0 var(--sc,#f00), 12px 0    0 var(--sc,#f00), 16px 0    0 var(--sc,#f00),
              -4px 4px  0 var(--sc,#f00), 0   4px  0 var(--sc,#f00), 4px  4px 0 var(--sc,#f00),
              8px 4px  0 var(--sc,#f00), 12px 4px 0 var(--sc,#f00), 16px 4px 0 var(--sc,#f00),
              20px 4px 0 var(--sc,#f00),
              -4px 8px  0 var(--sc,#f00), 0   8px  0 var(--sc,#f00), 4px  8px 0 var(--sc,#f00),
              8px 8px  0 var(--sc,#f00), 12px 8px 0 var(--sc,#f00), 16px 8px 0 var(--sc,#f00),
              20px 8px 0 var(--sc,#f00),
              0   12px 0 var(--sc,#f00), 4px 12px 0 var(--sc,#f00), 8px 12px 0 var(--sc,#f00),
              12px 12px 0 var(--sc,#f00), 16px 12px 0 var(--sc,#f00),
              4px 16px 0 var(--sc,#f00), 8px 16px 0 var(--sc,#f00), 12px 16px 0 var(--sc,#f00),
              8px 20px 0 var(--sc,#f00);
          }

          /* ── Floating SOUL heart containers ── */
          .ut-soul {
            position: fixed; bottom: -30px;
            pointer-events: none; z-index: 2;
            animation: floatSoul linear forwards;
          }

          /* ── Fixed player soul (bottom centre) ── */
          /* Heart is 7 cols × 6 rows at 10px/px = 70×60px.
             Wrapper is exactly that size so filter sees the full shape.
             Base div sits at left:10px inside wrapper (col 1 = 10px from left edge). */
          #ut-player-soul {
            position: fixed;
            bottom: 20px;
            left: calc(50% - 35px);   /* centre the 70px wrapper */
            width: 70px; height: 60px;
            animation: utHeartBeat 1s infinite;
            z-index: 100; pointer-events: none;
            filter: drop-shadow(0 0 12px #ff0000);
          }
          #ut-player-soul .ut-ph-lg {
            position: absolute; left: 10px; top: 0;
          }

          /* ── Save point star ── */
          #ut-savepoint {
            position: fixed; top: 20px; right: 24px;
            font-size: 1.6rem; color: var(--ut-yellow);
            animation: savepointSpin 4s linear infinite, starTwinkle 2s ease-in-out infinite;
            z-index: 100; pointer-events: none;
            filter: drop-shadow(0 0 10px #ffff00);
          }

          /* ── Pixel stars background ── */
          .ut-star {
            position: fixed; color: #fff; font-size: 0.5rem;
            pointer-events: none; z-index: 1;
            animation: starTwinkle ease-in-out infinite;
          }
        </style>

      <% } else { %>
        <!-- Classic Dojo Theme -->
        <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Open+Sans:wght@400;700&display=swap"
          rel="stylesheet">
        <style>
          :root {
            --dojo-red: #E63946;
            --dojo-black: #1a1a1a;
            --dojo-white: #ffffff;
            --text-muted: #666;
          }

          body {
            background-color: #f0f0f0;
            background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            color: var(--dojo-black);
            font-family: 'Open Sans', sans-serif;
          }

          .header {
            background: var(--dojo-black);
            color: white;
            border-bottom: 5px solid var(--dojo-red);
          }

          .kid-card {
            background: white;
            border: 4px solid var(--dojo-black);
            border-radius: 0;
            box-shadow: 10px 10px 0px var(--dojo-red);
            color: var(--dojo-black);
          }

          .kid-card h2 {
            color: var(--dojo-red);
            font-family: 'Bangers';
            font-size: 2.2rem;
          }

          .activity-item {
            border-left: 5px solid var(--dojo-red);
            background: #fafafa;
          }

          .activity-info a {
            background: var(--dojo-black);
            color: white;
            padding: 5px 15px;
            font-family: 'Bangers';
          }

          .event-date {
            background: var(--dojo-red);
            color: white;
            font-weight: bold;
            padding: 2px 10px;
          }

          .ninja-month-img {
            border: 4px solid var(--dojo-black);
            border-radius: 0;
            transform: rotate(-2deg);
          }

