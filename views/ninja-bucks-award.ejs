<%- include('partials/admin-header', { title: 'Award Ninja Bucks', active: 'award' }) %>

<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
  <div id="awardToast" class="toast align-items-center text-white border-0 shadow" role="alert">
    <div class="d-flex">
      <div class="toast-body fw-bold" id="toastMsg">Done!</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<div class="page-header d-flex justify-content-between align-items-center">
  <div>
    <h2 class="page-title" id="pageTitle">Award Ninja Bucks</h2>
    <p class="text-muted mb-0" id="pageSubtitle">Select a reason — the amount auto-fills to the standard value.</p>
  </div>
  <div class="d-flex align-items-center gap-2 bg-white border rounded-pill p-1 shadow-sm">
    <button id="awardTab" class="btn btn-primary rounded-pill px-4 py-2 fw-bold" onclick="setMode('award')">
      <i class="bi bi-plus-circle-fill me-2"></i>Award
    </button>
    <button id="removeTab" class="btn btn-light rounded-pill px-4 py-2 fw-bold text-secondary" onclick="setMode('remove')">
      <i class="bi bi-dash-circle-fill me-2"></i>Remove
    </button>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <div id="formCard" class="admin-card p-4 p-md-5 shadow-sm">

      <!-- Ninja selector with multi-select chips -->
      <div class="mb-4">
        <label class="form-label fw-bold text-dark">1. Select Ninja(s) <span class="text-muted fw-normal small">(search and add multiple)</span></label>
        <div id="selectedNinjasChips" class="d-flex flex-wrap gap-2 mb-2"></div>
        <div class="position-relative">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-person-search"></i></span>
            <input type="text" id="ninjaSearch" class="form-control border-start-0" placeholder="Start typing a name..." autocomplete="off">
          </div>
          <div id="ninjaDropdown" style="
            display:none; position:absolute; top:100%; left:0; right:0; z-index:1050;
            background:white; border:1px solid #dee2e6; border-top:none;
            border-radius:0 0 12px 12px; box-shadow:0 8px 24px rgba(0,0,0,0.1);
            max-height:260px; overflow-y:auto;
          "></div>
        </div>
        <div id="ninjaCountBadge" class="mt-2" style="display:none;">
          <span class="badge rounded-pill px-3 py-2" style="background:#e8f4fb; color:#1e6a94; border:1.5px solid #93c5fd; font-size:0.85rem; font-weight:600;">
            <i class="bi bi-people-fill me-1"></i> <strong id="ninjaSelectedCount">0</strong> ninja(s) selected
          </span>
        </div>
      </div>

      <!-- Reason pills (award mode) -->
      <div id="awardReasonSection" class="mb-4">
        <label class="form-label fw-bold text-dark">2. Reason <span class="text-muted fw-normal small">(tap to select &amp; auto-fill amount)</span></label>
        <div id="reasonPills" class="d-flex flex-wrap gap-2 mb-3">
          <!-- Populated by JS -->
        </div>
        <!-- Running total indicator -->
        <div id="selectedCount" class="small fw-bold text-primary mt-2" style="min-height:1.2em;"></div>
        <!-- Rules of Dojo: variable amount stepper -->
        <div id="dojoAmountWrap" class="align-items-center gap-2 mt-2" style="display:none;">
          <span class="small fw-bold text-muted">Rules of the Dojo amount:</span>
          <input type="number" id="dojoAmount" class="form-control form-control-sm" style="width:80px;" min="0" max="5" value="5" oninput="updateTotal()">
          <span class="small text-muted">(0–5 NB)</span>
        </div>
        <!-- Other: custom text input, hidden until "Other" is picked -->
        <div id="otherReasonWrap" style="display:none;" class="mt-2">
          <input type="text" id="otherReasonText" class="form-control" placeholder="Describe the reason..." maxlength="60">
        </div>
      </div>

      <!-- Reason dropdown (remove mode) -->
      <div id="removeReasonSection" class="mb-4" style="display:none;">
        <label class="form-label fw-bold text-dark">2. Reason</label>
        <select id="removeReason" class="form-select form-select-lg" onchange="document.getElementById('removeOtherWrap').style.display = this.value === 'Other' ? 'block' : 'none';">
          <option value="Shop Purchase">Shop Purchase</option>
          <option value="Merch Redemption">Merch Redemption</option>
          <option value="Event Ticket">Event Ticket</option>
          <option value="Manual Deduction">Manual Deduction</option>
          <option value="Correction / Reversal">Correction / Reversal</option>
          <option value="Other">Other</option>
        </select>
        <div id="removeOtherWrap" class="mt-2" style="display:none;">
          <input type="text" id="removeOtherText" class="form-control" placeholder="Specify custom reason...">
        </div>
      </div>

      <!-- Amount -->
      <div class="mb-4">
        <label class="form-label fw-bold text-dark">3. Amount (NB)</label>
        <div class="input-group input-group-lg">
          <span class="input-group-text" id="amountPrefix" style="background:#fffbeb; border-color:#fde68a; color:#92400e;"><i class="bi bi-coin"></i></span>
          <input type="number" id="amount" class="form-control" placeholder="0" min="1">
        </div>
      </div>

      <!-- Boss damage (only visible when boss is active and a damageable reason is selected) -->
      <div id="damageSection" class="mb-5" style="display:none;">
        <label class="form-label fw-bold text-dark">4. Boss Damage <span class="text-muted fw-normal small">(optional)</span></label>
        <div class="input-group input-group-lg">
          <span class="input-group-text" style="background:#fff5f5; border-color:#fed7d7; color:#c53030;"><i class="bi bi-lightning-fill"></i></span>
          <input type="number" id="damageAmount" class="form-control" placeholder="0 (skip)" min="0">
        </div>
        <div class="form-text mt-1 small">Damage each ninja deals to the boss. Leave blank to skip.</div>
      </div>

      <div class="d-grid">
        <button id="actionBtn" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow" onclick="submitAction()">
          <i class="bi bi-award-fill me-2"></i> Confirm Award
        </button>
      </div>
    </div>

  </div>
</div>

<style>
  #formCard.remove-mode { border-top: 4px solid #dc3545; }
  .reason-pill {
    cursor: pointer; border: 2px solid; border-radius: 50px;
    padding: 6px 16px; font-size: 0.85rem; font-weight: 600;
    transition: all 0.15s; user-select: none; white-space: nowrap;
  }
  .reason-pill .nb-badge {
    display: inline-block; margin-left: 6px;
    border-radius: 20px; padding: 1px 8px; font-size: 0.75rem; font-weight: 700;
  }

  /* +1 NB — blue */
  .pill-1 { border-color: #93c5fd; color: #1d4ed8; background: #eff6ff; }
  .pill-1 .nb-badge { background: #bfdbfe; color: #1d4ed8; }
  .pill-1:hover { background: #dbeafe; border-color: #3b82f6; }
  .pill-1.selected { background: #3b82f6; border-color: #2563eb; color: white; }
  .pill-1.selected .nb-badge { background: rgba(255,255,255,0.25); color: white; }

  /* +2 NB — purple */
  .pill-2 { border-color: #c4b5fd; color: #6d28d9; background: #f5f3ff; }
  .pill-2 .nb-badge { background: #ddd6fe; color: #6d28d9; }
  .pill-2:hover { background: #ede9fe; border-color: #8b5cf6; }
  .pill-2.selected { background: #8b5cf6; border-color: #7c3aed; color: white; }
  .pill-2.selected .nb-badge { background: rgba(255,255,255,0.25); color: white; }

  /* +5 NB — amber */
  .pill-5 { border-color: #fcd34d; color: #92400e; background: #fffbeb; }
  .pill-5 .nb-badge { background: #fde68a; color: #92400e; }
  .pill-5:hover { background: #fef3c7; border-color: #f59e0b; }
  .pill-5.selected { background: #f59e0b; border-color: #d97706; color: white; }
  .pill-5.selected .nb-badge { background: rgba(255,255,255,0.25); color: white; }

  /* +10 NB — red */
  .pill-10 { border-color: #fca5a5; color: #b91c1c; background: #fef2f2; }
  .pill-10 .nb-badge { background: #fecaca; color: #b91c1c; }
  .pill-10:hover { background: #fee2e2; border-color: #ef4444; }
  .pill-10.selected { background: #ef4444; border-color: #dc2626; color: white; }
  .pill-10.selected .nb-badge { background: rgba(255,255,255,0.25); color: white; }

  /* Autocomplete dropdown items */
  .ninja-option {
    padding: 10px 16px; cursor: pointer; font-weight: 600; font-size: 0.9rem;
    border-bottom: 1px solid #f3f4f6; transition: background 0.1s;
    display: flex; align-items: center; justify-content: space-between;
  }
  .ninja-option:last-child { border-bottom: none; }
  .ninja-option:hover, .ninja-option.active { background: #eff6ff; color: var(--cn-blue); }
  .ninja-option .match-highlight { color: var(--cn-blue); text-decoration: underline; }
  .ninja-option .ninja-nb-count {
    font-size: 0.75rem; font-weight: 700; color: #92400e;
    background: #fef3c7; border: 1px solid #fde68a;
    border-radius: 20px; padding: 2px 9px; white-space: nowrap; flex-shrink: 0; margin-left: 10px;
  }
  .ninja-option:hover .ninja-nb-count, .ninja-option.active .ninja-nb-count {
    background: #fde68a;
  }
  #ninjaSearch:focus { border-color: var(--cn-blue); box-shadow: 0 0 0 0.2rem rgba(53,142,188,.15); }

  /* Other — gray */
  .pill-other { border-color: #d1d5db; color: #4b5563; background: #f9fafb; }
  .pill-other .nb-badge { background: #e5e7eb; color: #4b5563; }
  .pill-other:hover { background: #f3f4f6; border-color: #9ca3af; }
  .pill-other.selected { background: #6b7280; border-color: #4b5563; color: white; }
  .pill-other.selected .nb-badge { background: rgba(255,255,255,0.25); color: white; }

  /* Multi-select ninja chips */
  .ninja-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #e8f4fb 0%, #dbeafe 100%);
    border: 1.5px solid #93c5fd; border-radius: 50px;
    padding: 5px 8px 5px 14px; font-size: 0.82rem; font-weight: 600;
    color: #1e6a94; animation: chipIn 0.2s ease-out;
  }
  .ninja-chip .chip-nb {
    font-size: 0.7rem; font-weight: 700; color: #92400e;
    background: #fef3c7; border-radius: 12px; padding: 1px 7px;
  }
  .ninja-chip .chip-remove {
    width: 20px; height: 20px; border-radius: 50%; border: none;
    background: rgba(0,0,0,0.08); color: #64748b; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; transition: all 0.15s; padding: 0; line-height: 1;
  }
  .ninja-chip .chip-remove:hover { background: #ef4444; color: white; }
  @keyframes chipIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
  .ninja-option.already-selected {
    opacity: 0.45; pointer-events: none; background: #f9fafb;
  }
</style>

<script>
  const BOSS_ACTIVE = <%= bossActive ? 'true' : 'false' %>;
  const BOSS_NAME   = <%- JSON.stringify(bossName || 'the boss') %>;
  const NO_DAMAGE_REASONS = new Set(['Other', 'Birthday', 'Daily Activity Challenge', 'Creative']);

  // ── Multi-select Ninja autocomplete ─────────────────────────────────────
  const ALL_NINJAS = <%- JSON.stringify(leaderboard.map(n => ({ name: n.name, total: n.total || 0 }))) %>;
  const NINJA_MAP = new Map(ALL_NINJAS.map(n => [n.name, n.total]));
  const selectedNinjas = new Map(); // name → { name, total }
  let activeIdx = -1;

  const searchInput  = document.getElementById('ninjaSearch');
  const dropdown     = document.getElementById('ninjaDropdown');
  const chipsContainer = document.getElementById('selectedNinjasChips');

  function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function highlight(name, query) {
    if (!query) return escapeHtml(name);
    const idx = name.toLowerCase().indexOf(query.toLowerCase());
    if (idx === -1) return escapeHtml(name);
    return escapeHtml(name.slice(0, idx))
      + `<span class="match-highlight">${escapeHtml(name.slice(idx, idx + query.length))}</span>`
      + escapeHtml(name.slice(idx + query.length));
  }

  function showDropdown(matches, query) {
    activeIdx = -1;
    dropdown.innerHTML = '';
    if (!matches.length) {
      dropdown.innerHTML = '<div class="ninja-option text-muted fst-italic">No ninjas found</div>';
    } else {
      matches.forEach(({ name, total }) => {
        const item = document.createElement('div');
        const alreadyPicked = selectedNinjas.has(name);
        item.className = 'ninja-option' + (alreadyPicked ? ' already-selected' : '');
        item.dataset.name = name;
        item.dataset.total = total;
        const checkMark = alreadyPicked ? '<i class="bi bi-check-circle-fill text-success me-2"></i>' : '';
        item.innerHTML = `<span>${checkMark}${highlight(name, query)}</span><span class="ninja-nb-count">${total} NB</span>`;
        if (!alreadyPicked) {
          item.addEventListener('mousedown', e => { e.preventDefault(); addNinja(name, total); });
        }
        dropdown.appendChild(item);
      });
    }
    dropdown.style.display = 'block';
  }

  function addNinja(name, total) {
    if (selectedNinjas.has(name)) return;
    const nb = total !== undefined ? total : (NINJA_MAP.get(name) ?? 0);
    selectedNinjas.set(name, { name, total: nb });
    renderChips();
    searchInput.value = '';
    dropdown.style.display = 'none';
    searchInput.focus();
  }

  function removeNinja(name) {
    selectedNinjas.delete(name);
    renderChips();
    searchInput.focus();
  }

  function renderChips() {
    chipsContainer.innerHTML = '';
    for (const [name, { total }] of selectedNinjas) {
      const chip = document.createElement('div');
      chip.className = 'ninja-chip';
      chip.innerHTML = `
        ${escapeHtml(name)}
        <span class="chip-nb">${total} NB</span>
        <button class="chip-remove" title="Remove" onclick="removeNinja('${escapeHtml(name.replace(/'/g, "\\'"))}')">
          <i class="bi bi-x"></i>
        </button>
      `;
      chipsContainer.appendChild(chip);
    }
    // Update count badge
    const badge = document.getElementById('ninjaCountBadge');
    const count = document.getElementById('ninjaSelectedCount');
    if (selectedNinjas.size > 0) {
      badge.style.display = 'block';
      count.textContent = selectedNinjas.size;
    } else {
      badge.style.display = 'none';
    }
  }

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim();
    if (!q) { dropdown.style.display = 'none'; return; }
    const matches = ALL_NINJAS.filter(n => n.name.toLowerCase().includes(q.toLowerCase())).slice(0, 10);
    showDropdown(matches, q);
  });

  // Keyboard navigation
  searchInput.addEventListener('keydown', e => {
    const items = dropdown.querySelectorAll('.ninja-option:not(.already-selected)');
    const allItems = dropdown.querySelectorAll('.ninja-option');
    if (!allItems.length || dropdown.style.display === 'none') return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, allItems.length - 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
    } else if (e.key === 'Enter' && activeIdx >= 0) {
      e.preventDefault();
      const el = allItems[activeIdx];
      if (!el.classList.contains('already-selected')) {
        addNinja(el.dataset.name, parseInt(el.dataset.total) || 0);
      }
      return;
    } else if (e.key === 'Escape') {
      dropdown.style.display = 'none'; return;
    }
    allItems.forEach((item, i) => item.classList.toggle('active', i === activeIdx && !item.classList.contains('already-selected')));
    if (activeIdx >= 0 && allItems[activeIdx]) allItems[activeIdx].scrollIntoView({ block: 'nearest' });
  });

  // Close when clicking outside
  document.addEventListener('mousedown', e => {
    if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.style.display = 'none';
    }
  });
  // ─────────────────────────────────────────────────────────────────────────

  const AWARD_REASONS = [
    { label: 'Completed Build/Quest',      amount: 2  },
    { label: 'Published Community Game',   amount: 2  },
    { label: 'Daily Activity Challenge',   amount: 2  },
    { label: 'Creative',                   amount: 1  },
    { label: 'Impact Level Up',            amount: 5  },
    { label: 'Got a Stripe',               amount: 5  },
    { label: 'Belt Up',                    amount: 5  },
    { label: 'Boss Badge',                 amount: 5  },
    { label: 'Birthday',                   amount: 5  },
    { label: 'Ninja of the Month',         amount: 5  },
    { label: 'Rules of the Dojo',          amount: null, variable: true },
    { label: 'Participated in Game Jam',   amount: 10 },
    { label: 'Other',                      amount: null }
  ];

  let currentMode = 'award';
  const selectedReasons = new Map(); // label → reason object

  function buildPills() {
    const container = document.getElementById('reasonPills');
    container.innerHTML = '';
    AWARD_REASONS.forEach(r => {
      const colorClass = r.variable ? 'pill-5' : (r.amount === null ? 'pill-other' : `pill-${r.amount}`);
      const pill = document.createElement('div');
      pill.className = `reason-pill ${colorClass}`;
      let badgeText = r.variable ? '0–5' : (r.amount !== null ? `+${r.amount}` : '✏️');
      pill.innerHTML = r.label + `<span class="nb-badge">${badgeText}</span>`;
      pill.dataset.label = r.label;
      pill.addEventListener('click', () => toggleReason(pill, r));
      container.appendChild(pill);
    });
  }

  function updateDamageSection(isAwardMode) {
    const hasDamageable = [...selectedReasons.keys()].some(l => !NO_DAMAGE_REASONS.has(l));
    const show = BOSS_ACTIVE && isAwardMode !== false && hasDamageable;
    document.getElementById('damageSection').style.display = show ? 'block' : 'none';
    if (!show) document.getElementById('damageAmount').value = '';
  }

  function toggleReason(pill, reason) {
    if (selectedReasons.has(reason.label)) {
      selectedReasons.delete(reason.label);
      pill.classList.remove('selected');
    } else {
      selectedReasons.set(reason.label, reason);
      pill.classList.add('selected');
    }
    // Show/hide variable inputs
    document.getElementById('otherReasonWrap').style.display   = selectedReasons.has('Other')            ? 'block' : 'none';
    document.getElementById('dojoAmountWrap').style.display    = selectedReasons.has('Rules of the Dojo') ? 'flex'  : 'none';
    updateTotal();
    updateDamageSection(true);
    if (reason.label === 'Other') document.getElementById('otherReasonText').focus();
    if (reason.label === 'Rules of the Dojo') document.getElementById('dojoAmount').focus();
  }

  function updateTotal() {
    let total = 0;
    for (const [label, r] of selectedReasons) {
      if (label === 'Rules of the Dojo') total += parseInt(document.getElementById('dojoAmount').value) || 0;
      else if (label === 'Other') total += 0; // user sets amount manually for Other
      else total += r.amount || 0;
    }
    if (selectedReasons.size > 0) document.getElementById('amount').value = total || '';
    const countEl = document.getElementById('selectedCount');
    if (countEl) countEl.textContent = selectedReasons.size
      ? `${selectedReasons.size} reason${selectedReasons.size > 1 ? 's' : ''} selected · +${total} NB`
      : '';
  }

  function setMode(mode) {
    currentMode = mode;
    const isRemove = mode === 'remove';
    const card = document.getElementById('formCard');
    const btn = document.getElementById('actionBtn');
    const prefix = document.getElementById('amountPrefix');
    const awardTab = document.getElementById('awardTab');
    const removeTab = document.getElementById('removeTab');

    document.getElementById('awardReasonSection').style.display = isRemove ? 'none' : 'block';
    document.getElementById('removeReasonSection').style.display = isRemove ? 'block' : 'none';
    if (isRemove) { document.getElementById('damageSection').style.display = 'none'; document.getElementById('damageAmount').value = ''; }

    if (isRemove) {
      card.classList.add('remove-mode');
      btn.className = 'btn btn-danger btn-lg rounded-pill py-3 fw-bold shadow';
      btn.innerHTML = '<i class="bi bi-dash-circle-fill me-2"></i> Confirm Removal';
      document.getElementById('pageTitle').textContent = 'Remove Ninja Bucks';
      document.getElementById('pageSubtitle').textContent = 'Deduct bucks for shop purchases or corrections.';
      prefix.style.cssText = 'background:#fff5f5; border-color:#fed7d7; color:#c53030;';
      awardTab.className = 'btn btn-light rounded-pill px-4 py-2 fw-bold text-secondary';
      removeTab.className = 'btn btn-danger rounded-pill px-4 py-2 fw-bold';
    } else {
      card.classList.remove('remove-mode');
      btn.className = 'btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow';
      btn.innerHTML = '<i class="bi bi-award-fill me-2"></i> Confirm Award';
      document.getElementById('pageTitle').textContent = 'Award Ninja Bucks';
      document.getElementById('pageSubtitle').textContent = 'Select a reason — the amount auto-fills to the standard value.';
      prefix.style.cssText = 'background:#fffbeb; border-color:#fde68a; color:#92400e;';
      awardTab.className = 'btn btn-primary rounded-pill px-4 py-2 fw-bold';
      removeTab.className = 'btn btn-light rounded-pill px-4 py-2 fw-bold text-secondary';
    }
  }

  function showToast(msg, type = 'success') {
    const el = document.getElementById('awardToast');
    document.getElementById('toastMsg').textContent = msg;
    el.className = `toast align-items-center text-white bg-${type} border-0 shadow`;
    bootstrap.Toast.getOrCreateInstance(el, { delay: 4000 }).show();
  }

  function resetForm() {
    document.getElementById('amount').value = '';
    document.getElementById('damageAmount').value = '';
    selectedReasons.clear();
    document.querySelectorAll('.reason-pill').forEach(p => p.classList.remove('selected'));
    document.getElementById('otherReasonWrap').style.display = 'none';
    document.getElementById('dojoAmountWrap').style.display = 'none';
    document.getElementById('damageSection').style.display = 'none';
    document.getElementById('otherReasonText').value = '';
    document.getElementById('dojoAmount').value = '5';
    document.getElementById('selectedCount').textContent = '';
    selectedNinjas.clear();
    renderChips();
    searchInput.value = '';
  }

  async function submitAction() {
    const ninjaNames = [...selectedNinjas.keys()];
    const amount = parseInt(document.getElementById('amount').value);
    const btn = document.getElementById('actionBtn');
    const isRemove = currentMode === 'remove';

    let reason;
    if (isRemove) {
      reason = document.getElementById('removeReason').value;
      if (reason === 'Other') reason = document.getElementById('removeOtherText').value.trim() || 'Other';
    } else {
      if (!selectedReasons.size) { showToast('Please select at least one reason.', 'warning'); return; }
      const parts = [...selectedReasons.keys()].map(label => {
        if (label === 'Other') return document.getElementById('otherReasonText').value.trim() || 'Other';
        return label;
      });
      reason = parts.join(' · ');
    }

    if (!ninjaNames.length) {
      showToast('Please select at least one ninja.', 'warning'); return;
    }
    if (!amount || amount <= 0) {
      showToast('Please enter a valid amount.', 'warning'); return;
    }

    const damageDealt = parseInt(document.getElementById('damageAmount')?.value) || 0;
    const finalAmount = isRemove ? -amount : amount;
    btn.disabled = true;
    const actionLabel = isRemove ? 'Removing' : 'Awarding';
    btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>${actionLabel}...`;

    try {
      let msg;
      if (ninjaNames.length === 1) {
        // Single ninja — use the original endpoint
        const res = await fetch('/admin/update-ninja-bucks', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ninjaName: ninjaNames[0], amount: finalAmount, reason, damageDealt })
        });
        const data = await res.json();
        if (!data.success) { showToast('Error: ' + (data.error || 'Ninja not found.'), 'danger'); return; }
        NINJA_MAP.set(ninjaNames[0], data.newTotal);
        msg = isRemove
          ? `Removed ${amount} NB from ${ninjaNames[0]}. Balance: ${data.newTotal} NB`
          : `${amount} NB awarded to ${ninjaNames[0]}! Balance: ${data.newTotal} NB`;
        if (!isRemove && damageDealt > 0) msg += ` · ${damageDealt} dmg to ${BOSS_NAME}`;
      } else {
        // Multiple ninjas — use the bulk endpoint
        const res = await fetch('/admin/update-ninja-bucks-bulk', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ninjaNames, amount: finalAmount, reason, damageDealt })
        });
        const data = await res.json();
        if (!data.success) { showToast('Error: ' + (data.error || 'Bulk update failed.'), 'danger'); return; }
        // Update local cache
        for (const r of data.results) { NINJA_MAP.set(r.name, r.newTotal); }
        const names = data.results.map(r => r.name).join(', ');
        msg = isRemove
          ? `Removed ${amount} NB from ${data.results.length} ninja(s): ${names}`
          : `${amount} NB awarded to ${data.results.length} ninja(s): ${names}`;
        if (!isRemove && damageDealt > 0) msg += ` · ${damageDealt} dmg each to ${BOSS_NAME}`;
      }
      showToast(msg, isRemove ? 'warning' : 'success');
      resetForm();
    } catch(e) { showToast('Network error.', 'danger'); }
    finally {
      btn.disabled = false;
      btn.innerHTML = isRemove
        ? '<i class="bi bi-dash-circle-fill me-2"></i> Confirm Removal'
        : '<i class="bi bi-award-fill me-2"></i> Confirm Award';
    }
  }

  // Init
  buildPills();
  setMode('award');
</script>

<%- include('partials/admin-footer') %>
