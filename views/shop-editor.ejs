<%- include('partials/admin-header', { title: 'Edit Shop', active: 'editor' }) %>

<div class="page-header d-flex justify-content-between align-items-end">
  <div>
    <h2 class="page-title">Shop Management</h2>
    <p class="text-muted mb-0">Manage items, prices, and inventory available for ninjas.</p>
  </div>
</div>

<form action="/admin/update-shop" method="POST">
  <div class="admin-card p-4 shadow-sm mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h5 class="fw-bold mb-0"><i class="bi bi-cart4 text-primary me-2"></i> Inventory Items</h5>
      <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="addItem()">
        <i class="bi bi-plus-lg me-1"></i> Add New Item
      </button>
    </div>

    <div id="itemList" class="row g-3">
      <% (data.shopItems || []).forEach((item, i) => { %>
        <div class="col-md-6 col-xl-4 shop-item-row">
          <div class="border rounded-4 p-3 bg-light bg-opacity-50 h-100 position-relative">
            <button type="button" class="btn-close position-absolute top-0 end-0 m-3" onclick="this.closest('.shop-item-row').remove()"></button>
            
            <div class="mb-3">
              <label class="small fw-bold text-muted text-uppercase">Item Name</label>
              <input type="text" name="shop_name_<%= i %>" class="form-control" value="<%= item.name %>" required>
            </div>
            
            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="small fw-bold text-muted text-uppercase">Price (NB)</label>
                <div class="input-group">
                  <span class="input-group-text bg-white"><i class="bi bi-coin text-warning"></i></span>
                  <input type="number" name="shop_price_<%= i %>" class="form-control" value="<%= item.price %>" required>
                </div>
              </div>
              <div class="col-6">
                <label class="small fw-bold text-muted text-uppercase">Category</label>
                <select name="shop_category_<%= i %>" class="form-select">
                  <option value="Merch" <%= item.category === 'Merch' ? 'selected' : '' %>>Merch</option>
                  <option value="Snacks" <%= item.category === 'Snacks' ? 'selected' : '' %>>Snacks</option>
                  <option value="Events" <%= item.category === 'Events' ? 'selected' : '' %>>Events</option>
                  <option value="Toys" <%= item.category === 'Toys' ? 'selected' : '' %>>Toys</option>
                </select>
              </div>
            </div>

            <div class="mb-3">
              <label class="small fw-bold text-muted text-uppercase">Icon / Image URL</label>
              <input type="text" name="shop_image_<%= i %>" class="form-control" value="<%= item.image %>" placeholder="bi-gift">
            </div>

            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="shop_outOfStock_<%= i %>" <%= item.outOfStock ? 'checked' : '' %>>
              <label class="form-check-label small fw-bold">Out of Stock</label>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="text-end">
    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow">
      <i class="bi bi-check-all me-2"></i> Save Inventory
    </button>
  </div>
</form>

<script>
  function addItem() {
    const container = document.getElementById('itemList');
    const index = container.querySelectorAll('.shop-item-row').length;
    const div = document.createElement('div');
    div.className = 'col-md-6 col-xl-4 shop-item-row';
    div.innerHTML = `
      <div class="border rounded-4 p-3 bg-light bg-opacity-50 h-100 position-relative">
        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" onclick="this.closest('.shop-item-row').remove()"></button>
        <div class="mb-3">
          <label class="small fw-bold text-muted text-uppercase">Item Name</label>
          <input type="text" name="shop_name_${index}" class="form-control" placeholder="e.g. Code Ninjas Sticker" required>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="small fw-bold text-muted text-uppercase">Price (NB)</label>
            <input type="number" name="shop_price_${index}" class="form-control" value="10" required>
          </div>
          <div class="col-6">
            <label class="small fw-bold text-muted text-uppercase">Category</label>
            <select name="shop_category_${index}" class="form-select">
              <option value="Merch">Merch</option>
              <option value="Snacks">Snacks</option>
              <option value="Events">Events</option>
              <option value="Toys">Toys</option>
            </select>
          </div>
        </div>
        <div class="mb-3">
          <label class="small fw-bold text-muted text-uppercase">Icon / Image URL</label>
          <input type="text" name="shop_image_${index}" class="form-control" placeholder="bi-gift">
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="shop_outOfStock_${index}">
          <label class="form-check-label small fw-bold">Out of Stock</label>
        </div>
      </div>
    `;
    container.appendChild(div);
  }
</script>

<%- include('partials/admin-footer') %>
